<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_tc10_xor_exec_before_merge_then_adhoc" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc10_xor_exec_before_merge_then_adhoc_E1" name="Extracted Fragment E1" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_E1" name="Start">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_Input" name="Upload Research Dataset">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.datasetUrl" label="Dataset URL" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <qhana:qHAnaServiceTask id="QHanaTask_CleanData" name="clean-dataset">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">clean-dataset</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.datasetUrl}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.cleanedData">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <bpmn:exclusiveGateway id="Gateway_Split" name="Select Algorithm (XOR)" default="Flow_4B">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4A</bpmn:outgoing>
      <bpmn:outgoing>Flow_4B</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <qhana:qHAnaServiceTask id="QHanaTask_AlgoA" name="run-algorithm-a">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">run-algorithm-a</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.cleanedData}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.algoResult">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_4A</bpmn:incoming>
      <bpmn:outgoing>Flow_E1_end_0</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <qhana:qHAnaServiceTask id="QHanaTask_AlgoB" name="run-algorithm-b">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">run-algorithm-b</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.cleanedData}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.algoResult">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_4B</bpmn:incoming>
      <bpmn:outgoing>Flow_E1_end_1</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <bpmn:endEvent id="EndEvent_E1" name="End">
      <bpmn:incoming>Flow_E1_end_0</bpmn:incoming>
      <bpmn:incoming>Flow_E1_end_1</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="UserTask_Input" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="QHanaTask_CleanData" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="QHanaTask_CleanData" targetRef="Gateway_Split" />
    <bpmn:sequenceFlow id="Flow_4A" name="Use Algo A" sourceRef="Gateway_Split" targetRef="QHanaTask_AlgoA">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${method == 'A'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_4B" name="Default (Algo B)" sourceRef="Gateway_Split" targetRef="QHanaTask_AlgoB" />
    <bpmn:sequenceFlow id="Flow_E1_end_0" sourceRef="QHanaTask_AlgoA" targetRef="EndEvent_E1" />
    <bpmn:sequenceFlow id="Flow_E1_end_1" sourceRef="QHanaTask_AlgoB" targetRef="EndEvent_E1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc10_xor_exec_before_merge_then_adhoc_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc10_xor_exec_before_merge_then_adhoc_E1" bpmnElement="tc10_xor_exec_before_merge_then_adhoc_E1">
      <bpmndi:BPMNShape id="UserTask_Input_di" bpmnElement="UserTask_Input">
