      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="QHanaTask_AlgoB_di" bpmnElement="QHanaTask_AlgoB">
        <dc:Bounds x="750" y="380" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E1_di" bpmnElement="StartEvent_E1">
        <dc:Bounds x="80" y="250" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_E1_di" bpmnElement="EndEvent_E1">
        <dc:Bounds x="970" y="402" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="330" y="268" />
        <di:waypoint x="390" y="268" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="560" y="268" />
        <di:waypoint x="620" y="268" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4A_di" bpmnElement="Flow_4A">
        <di:waypoint x="645" y="243" />
        <di:waypoint x="645" y="120" />
        <di:waypoint x="750" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="660" y="100" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4B_di" bpmnElement="Flow_4B">
        <di:waypoint x="645" y="293" />
        <di:waypoint x="645" y="420" />
        <di:waypoint x="750" y="420" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="660" y="430" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_start_di" bpmnElement="Flow_E1_start">
        <di:waypoint x="116" y="268" />
        <di:waypoint x="160" y="268" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_end_0_di" bpmnElement="Flow_E1_end_0">
        <di:waypoint x="855" y="160" />
        <di:waypoint x="917" y="160" />
        <di:waypoint x="917" y="402" />
        <di:waypoint x="978" y="402" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_end_1_di" bpmnElement="Flow_E1_end_1">
