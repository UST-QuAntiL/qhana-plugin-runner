<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" id="Definitions_tc10_xor_exec_before_merge_then_adhoc" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc10_xor_exec_before_merge_then_adhoc_E1" name="Extracted Fragment E1" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E1">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_Input" name="Upload Research Dataset">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.datasetUrl" label="Dataset URL" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <qhana:qHAnaServiceTask id="QHanaTask_CleanData" name="clean-dataset">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">clean-dataset</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.datasetUrl}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.cleanedData">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_E1_end</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <bpmn:endEvent id="EndEvent_E1">
      <bpmn:incoming>Flow_E1_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="UserTask_Input" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="QHanaTask_CleanData" />
    <bpmn:sequenceFlow id="Flow_E1_end" sourceRef="QHanaTask_CleanData" targetRef="EndEvent_E1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc10_xor_exec_before_merge_then_adhoc_E1">
