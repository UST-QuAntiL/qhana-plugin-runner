      <bpmndi:BPMNShape id="QHanaTask_LaunchAds_di" bpmnElement="QHanaTask_LaunchAds">
        <omgdc:Bounds x="780" y="475" width="150" height="70" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Merge_di" bpmnElement="Gateway_Merge">
        <omgdc:Bounds x="1020" y="343" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <omgdc:Bounds x="1010" y="400" width="70" height="14" />
        </bpmndi:BPMNLabel>
