<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" id="Definitions_tc24_non_convertible_tasks" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc24_non_convertible_tasks_E1" name="Extracted Fragment E1" isExecutable="true" camunda:historyTimeToLive="180">
