    <qhana:qHAnaServiceTask id="QHanaTask_Finalize" name="finalize-data">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">finalize-data</camunda:inputParameter>
