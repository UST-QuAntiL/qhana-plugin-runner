<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_tc52_parallel_end_events" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc52_parallel_end_events_E1" name="Extracted Fragment E1" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E1" name="Start">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="ServiceTask_ArchiveA" name="archive-stream-a" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">placeholder-archive-a</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.archiveA">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_End_A</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_A" name="End A">
      <bpmn:incoming>Flow_End_A</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="ServiceTask_ArchiveA" />
    <bpmn:sequenceFlow id="Flow_End_A" sourceRef="ServiceTask_ArchiveA" targetRef="EndEvent_A" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc52_parallel_end_events_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc52_parallel_end_events_E1" bpmnElement="tc52_parallel_end_events_E1">
      <bpmndi:BPMNShape id="ServiceTask_ArchiveA_di" bpmnElement="ServiceTask_ArchiveA">
