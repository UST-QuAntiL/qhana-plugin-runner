<?xml version='1.0' encoding='utf-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" id="Definitions_TC10_ServiceTask_NonExec" targetNamespace="http://qhana.example/testcases">

  <process id="tc10_service_task_nonexec_exec" name="TC10 ServiceTask Non-Exec Mapping (exec split)" isExecutable="true">
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>SplitFlow_tc10_service_task_nonexec_exec_2</outgoing></startEvent>

    <serviceTask id="QHanaTask_HelloWorld" name="HelloWorld (QHAna)" camunda:type="external" camunda:topic="qhana-task" qhana:customFlag="exec-service">
      <extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">hello-world</camunda:inputParameter>
          <camunda:inputParameter name="qinput.inputStr">${qoutput.userInput}</camunda:inputParameter>
          <camunda:outputParameter name="result.qoutput.helloWorldResult">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </extensionElements>
    <outgoing>Flow_4</outgoing><incoming>SplitFlow_tc10_service_task_nonexec_exec_2</incoming></serviceTask>

    <endEvent id="EndEvent_1" name="End">
      <incoming>Flow_4</incoming></endEvent>

    <sequenceFlow id="Flow_4" sourceRef="QHanaTask_HelloWorld" targetRef="EndEvent_1" />
  <sequenceFlow id="SplitFlow_tc10_service_task_nonexec_exec_2" sourceRef="StartEvent_1" targetRef="QHanaTask_HelloWorld" /></process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="tc10_service_task_nonexec_exec">
      <bpmndi:BPMNShape id="Shape_StartEvent_1" bpmnElement="StartEvent_1">
        <omgdc:Bounds x="120" y="110" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_QHanaTask_HelloWorld" bpmnElement="QHanaTask_HelloWorld">
        <omgdc:Bounds x="510" y="88" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_1" bpmnElement="EndEvent_1">
        <omgdc:Bounds x="670" y="110" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Edge_Flow_4" bpmnElement="Flow_4">
        <omgdi:waypoint x="610" y="128" />
        <omgdi:waypoint x="670" y="128" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>