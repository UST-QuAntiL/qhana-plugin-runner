  <process id="hello_world_adhoc_test_exec" name="Hello World + Ad-hoc Subprocess Test (exec split)" isExecutable="true" camunda:versionTag="0.1">

    
    <startEvent id="StartEvent_1" name="Start">
      <outgoing>SplitFlow_hello_world_adhoc_test_exec_1</outgoing></startEvent>

    
    <endEvent id="EndEvent_1" name="End">
      <incoming>SplitFlow_hello_world_adhoc_test_exec_1</incoming></endEvent>

    
    <sequenceFlow id="SplitFlow_hello_world_adhoc_test_exec_1" sourceRef="StartEvent_1" targetRef="EndEvent_1" /></process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="hello_world_adhoc_test_exec">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <omgdc:Bounds x="150" y="120" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <omgdc:Bounds x="880" y="120" width="36" height="36" />
      </bpmndi:BPMNShape>

      </bpmndi:BPMNPlane>
