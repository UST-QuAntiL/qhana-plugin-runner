<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_tc57_escalation_end" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc57_escalation_end_E1" name="Extracted Fragment E1" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_E1" name="Start">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="ServiceTask_Check" name="check-threshold" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">placeholder-check</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.severity">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Severity" default="Flow_Normal">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Urgent</bpmn:outgoing>
      <bpmn:outgoing>Flow_Normal</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_Normal" name="End">
      <bpmn:incoming>Flow_Normal</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Escalated" name="Escalated ">
      <bpmn:escalationEventDefinition escalationRef="Escalation_Urgent" />
      <bpmn:incoming>Flow_Urgent</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="ServiceTask_Check" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="ServiceTask_Check" targetRef="Gateway_Severity" />
    <bpmn:sequenceFlow id="Flow_Urgent" sourceRef="Gateway_Severity" targetRef="EndEvent_Escalated">
      <bpmn:conditionExpression>${qoutput.severity == 'urgent'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Normal" sourceRef="Gateway_Severity" targetRef="EndEvent_Normal" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc57_escalation_end_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc57_escalation_end_E1" bpmnElement="tc57_escalation_end_E1">
      <bpmndi:BPMNShape id="ServiceTask_Check_di" bpmnElement="ServiceTask_Check">
        <dc:Bounds x="160" y="198" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Severity_di" bpmnElement="Gateway_Severity">
        <dc:Bounds x="340" y="213" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Normal_di" bpmnElement="EndEvent_Normal">
        <dc:Bounds x="450" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Escalated_di" bpmnElement="EndEvent_Escalated">
        <dc:Bounds x="450" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E1_di" bpmnElement="StartEvent_E1">
        <dc:Bounds x="80" y="220" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="300" y="238" />
        <di:waypoint x="340" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Urgent_di" bpmnElement="Flow_Urgent">
        <di:waypoint x="365" y="213" />
        <di:waypoint x="365" y="120" />
        <di:waypoint x="450" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Normal_di" bpmnElement="Flow_Normal">
        <di:waypoint x="365" y="263" />
        <di:waypoint x="365" y="360" />
        <di:waypoint x="450" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_start_di" bpmnElement="Flow_E1_start">
        <di:waypoint x="116" y="238" />
        <di:waypoint x="160" y="238" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>