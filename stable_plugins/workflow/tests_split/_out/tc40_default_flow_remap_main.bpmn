<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_tc40_default_flow_remap" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc40_default_flow_remap_main" name="TC40 - Default Flow Remap" isExecutable="true" camunda:versionTag="0.2">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:exclusiveGateway id="Gateway_Split" name="Check Quality" default="Flow_Target_Exec">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_Target_Exec</bpmn:outgoing>
      <bpmn:outgoing>Flow_Target_AdHoc</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:adHocSubProcess id="AdHoc_E1_Wrapper" name="Extracted Fragment E1" qhana:fragmentRef="E1">
      <bpmn:startEvent id="StartEvent_AdHoc_E1_Wrapper">
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_in</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="ServiceTask_E1_Plugin" name="Extracted Fragment E1" camunda:type="external" camunda:topic="plugin-step.tc40_default_flow_remap-E1">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_in</bpmn:incoming>
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_out</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="EndEvent_AdHoc_E1_Wrapper">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_out</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_in" sourceRef="StartEvent_AdHoc_E1_Wrapper" targetRef="ServiceTask_E1_Plugin" />
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_out" sourceRef="ServiceTask_E1_Plugin" targetRef="EndEvent_AdHoc_E1_Wrapper" />
      <bpmn:incoming>Flow_Target_Exec</bpmn:incoming>
      <bpmn:outgoing>Flow_EndA</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:adHocSubProcess id="AdHocSubProcess_Manual" name="Manual Repair" ordering="Parallel">
      <qhana:qHAnaServiceTask id="QHanaTask_Manual" name="manual-repair">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">manual-repair</camunda:inputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
      <bpmn:incoming>Flow_Target_AdHoc</bpmn:incoming>
      <bpmn:outgoing>Flow_EndB</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_EndA</bpmn:incoming>
      <bpmn:incoming>Flow_EndB</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Gateway_Split" />
    <bpmn:sequenceFlow id="Flow_Target_Exec" name="Default" sourceRef="Gateway_Split" targetRef="AdHoc_E1_Wrapper" />
    <bpmn:sequenceFlow id="Flow_Target_AdHoc" name="Failed Check" sourceRef="Gateway_Split" targetRef="AdHocSubProcess_Manual">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${quality == 'fail'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_EndA" sourceRef="AdHoc_E1_Wrapper" targetRef="EndEvent_1" />
    <bpmn:sequenceFlow id="Flow_EndB" sourceRef="AdHocSubProcess_Manual" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc40_default_flow_remap_main">
    <bpmndi:BPMNPlane id="BPMNPlane_tc40_default_flow_remap_main" bpmnElement="tc40_default_flow_remap_main">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="100" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Split_di" bpmnElement="Gateway_Split" isMarkerVisible="true">
        <dc:Bounds x="200" y="193" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="190" y="163" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AdHoc_E1_Wrapper_di" bpmnElement="AdHoc_E1_Wrapper" isExpanded="true">
        <dc:Bounds x="340" y="70" width="170" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AdHocSubProcess_Manual_di" bpmnElement="AdHocSubProcess_Manual" isExpanded="true">
        <dc:Bounds x="350" y="250" width="350" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="QHanaTask_Manual_di" bpmnElement="QHanaTask_Manual">
        <dc:Bounds x="400" y="290" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="800" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="136" y="218" />
        <di:waypoint x="200" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Target_Exec_di" bpmnElement="Flow_Target_Exec">
        <di:waypoint x="250" y="205" />
        <di:waypoint x="295" y="205" />
        <di:waypoint x="295" y="161" />
        <di:waypoint x="340" y="161" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Target_AdHoc_di" bpmnElement="Flow_Target_AdHoc">
        <di:waypoint x="225" y="243" />
        <di:waypoint x="225" y="325" />
        <di:waypoint x="350" y="325" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="240" y="335" width="65" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EndA_di" bpmnElement="Flow_EndA">
        <di:waypoint x="510" y="141" />
        <di:waypoint x="655" y="141" />
        <di:waypoint x="655" y="213" />
        <di:waypoint x="800" y="213" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_EndB_di" bpmnElement="Flow_EndB">
        <di:waypoint x="700" y="325" />
        <di:waypoint x="750" y="325" />
        <di:waypoint x="750" y="218" />
        <di:waypoint x="800" y="218" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>