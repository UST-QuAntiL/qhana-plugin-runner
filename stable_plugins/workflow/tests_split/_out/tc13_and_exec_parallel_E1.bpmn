<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" id="Definitions_tc13_and_exec_parallel" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc13_and_exec_parallel_E1" name="Extracted Fragment E1" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_E1" name="Start">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_Input" name="Submit Employee Details">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.employeeData" label="Employee Data" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:parallelGateway id="Gateway_Split" name="Parallel Onboarding Split">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3A</bpmn:outgoing>
      <bpmn:outgoing>Flow_3B</bpmn:outgoing>
    </bpmn:parallelGateway>
    <qhana:qHAnaServiceTask id="QHanaTask_ITProvision" name="provision-it-account">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">provision-it-account</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.employeeData}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.itAccountData">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3A</bpmn:incoming>
      <bpmn:outgoing>Flow_4A</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <qhana:qHAnaServiceTask id="QHanaTask_PayrollSetup" name="setup-payroll">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">setup-payroll</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.employeeData}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.payrollData">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3B</bpmn:incoming>
      <bpmn:outgoing>Flow_4B</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <bpmn:parallelGateway id="Gateway_Merge" name="Join Onboarding Tasks">
      <bpmn:incoming>Flow_4A</bpmn:incoming>
      <bpmn:incoming>Flow_4B</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="UserTask_Input" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="Gateway_Split" />
    <bpmn:sequenceFlow id="Flow_3A" name="IT Branch" sourceRef="Gateway_Split" targetRef="QHanaTask_ITProvision" />
    <bpmn:sequenceFlow id="Flow_3B" name="HR Branch" sourceRef="Gateway_Split" targetRef="QHanaTask_PayrollSetup" />
    <bpmn:sequenceFlow id="Flow_4A" sourceRef="QHanaTask_ITProvision" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_4B" sourceRef="QHanaTask_PayrollSetup" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_Merge" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc13_and_exec_parallel_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc13_and_exec_parallel_E1" bpmnElement="tc13_and_exec_parallel_E1">
      <bpmndi:BPMNShape id="UserTask_Input_di" bpmnElement="UserTask_Input">
        <dc:Bounds x="160" y="178" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Split_di" bpmnElement="Gateway_Split">
        <dc:Bounds x="390" y="193" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="375" y="160" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="QHanaTask_ITProvision_di" bpmnElement="QHanaTask_ITProvision">
        <dc:Bounds x="550" y="80" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="QHanaTask_PayrollSetup_di" bpmnElement="QHanaTask_PayrollSetup">
        <dc:Bounds x="550" y="280" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Merge_di" bpmnElement="Gateway_Merge">
        <dc:Bounds x="810" y="193" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="795" y="250" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="920" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E1_di" bpmnElement="StartEvent_E1">
        <dc:Bounds x="80" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="330" y="218" />
        <di:waypoint x="390" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3A_di" bpmnElement="Flow_3A">
        <di:waypoint x="415" y="193" />
        <di:waypoint x="415" y="120" />
        <di:waypoint x="550" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="460" y="100" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3B_di" bpmnElement="Flow_3B">
        <di:waypoint x="415" y="243" />
        <di:waypoint x="415" y="320" />
        <di:waypoint x="550" y="320" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="460" y="330" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4A_di" bpmnElement="Flow_4A">
        <di:waypoint x="720" y="120" />
        <di:waypoint x="835" y="120" />
        <di:waypoint x="835" y="193" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4B_di" bpmnElement="Flow_4B">
        <di:waypoint x="720" y="320" />
        <di:waypoint x="835" y="320" />
        <di:waypoint x="835" y="243" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="860" y="218" />
        <di:waypoint x="920" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_start_di" bpmnElement="Flow_E1_start">
        <di:waypoint x="116" y="218" />
        <di:waypoint x="160" y="218" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>