<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:ns1="http://qhana.example/custom-metadata" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" id="Definitions_tc38_custom_attributes" targetNamespace="http://qhana.example/testcases" ns1:suite="phase1" ns1:owner="thesis"><bpmn:process id="tc38_custom_attributes_E1" name="Extracted Fragment E1" isExecutable="true"><bpmn:startEvent id="StartEvent_E1"><bpmn:outgoing>Flow_E1_start</bpmn:outgoing></bpmn:startEvent><qhana:qHAnaServiceTask id="QHanaTask_Metadata" name="metadata-task" ns1:customTag="alpha" ns1:pluginFamily="demo">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">metadata-task</camunda:inputParameter>
          <camunda:inputParameter name="qinput.seed">metadata-seed</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.metadataValue">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    <bpmn:incoming>Flow_E1_start</bpmn:incoming><bpmn:outgoing>Flow_2</bpmn:outgoing></qhana:qHAnaServiceTask>

    <bpmn:userTask id="UserTask_Confirm" name="Confirm Metadata" ns1:uiGroup="review" ns1:displayMode="expanded">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.confirmation" label="Confirmation" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
    <bpmn:incoming>Flow_2</bpmn:incoming><bpmn:outgoing>Flow_E1_end</bpmn:outgoing></bpmn:userTask>

    <bpmn:endEvent id="EndEvent_E1"><bpmn:incoming>Flow_E1_end</bpmn:incoming></bpmn:endEvent><bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="QHanaTask_Metadata" /><bpmn:sequenceFlow id="Flow_2" sourceRef="QHanaTask_Metadata" targetRef="UserTask_Confirm" ns1:edgeClass="handover" />
    <bpmn:sequenceFlow id="Flow_E1_end" sourceRef="UserTask_Confirm" targetRef="EndEvent_E1" /></bpmn:process><bpmndi:BPMNDiagram id="BPMNDiagram_tc38_custom_attributes_E1"><bpmndi:BPMNPlane id="BPMNPlane_tc38_custom_attributes_E1" bpmnElement="tc38_custom_attributes_E1"><bpmndi:BPMNShape id="QHanaTask_Metadata_di" bpmnElement="QHanaTask_Metadata">
        <omgdc:Bounds x="170" y="168" width="190" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="UserTask_Confirm_di" bpmnElement="UserTask_Confirm">
        <omgdc:Bounds x="440" y="168" width="190" height="80" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_E1_di" bpmnElement="StartEvent_E1"><omgdc:Bounds x="90" y="190" width="36" height="36" /></bpmndi:BPMNShape><bpmndi:BPMNShape id="EndEvent_E1_di" bpmnElement="EndEvent_E1"><omgdc:Bounds x="680" y="190" width="36" height="36" /></bpmndi:BPMNShape><bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <omgdi:waypoint x="360" y="208" />
        <omgdi:waypoint x="440" y="208" />
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_E1_start_di" bpmnElement="Flow_E1_start"><omgdi:waypoint x="126" y="208" /><omgdi:waypoint x="170" y="208" /></bpmndi:BPMNEdge><bpmndi:BPMNEdge id="Flow_E1_end_di" bpmnElement="Flow_E1_end"><omgdi:waypoint x="630" y="208" /><omgdi:waypoint x="680" y="208" /></bpmndi:BPMNEdge></bpmndi:BPMNPlane></bpmndi:BPMNDiagram></bpmn:definitions>