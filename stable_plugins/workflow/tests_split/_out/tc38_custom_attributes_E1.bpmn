<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:ns1="http://qhana.example/custom-metadata" xmlns:qhana="https://github.com/qhana" id="Definitions_tc38_custom_attributes" targetNamespace="http://qhana.example/testcases" ns1:suite="phase1" ns1:owner="thesis">
  <bpmn:process id="tc38_custom_attributes_E1" name="Extracted Fragment E1" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E1" name="Start">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <qhana:qHAnaServiceTask id="QHanaTask_Metadata" name="metadata-task" ns1:customTag="alpha" ns1:pluginFamily="demo">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">metadata-task</camunda:inputParameter>
          <camunda:inputParameter name="qinput.seed">metadata-seed</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.metadataValue">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <bpmn:userTask id="UserTask_Confirm" name="Confirm Metadata" ns1:uiGroup="review" ns1:displayMode="expanded">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.confirmation" label="Confirmation" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="EndEvent_1" name="End" ns1:exit="true">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="QHanaTask_Metadata" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="QHanaTask_Metadata" targetRef="UserTask_Confirm" ns1:edgeClass="handover" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="UserTask_Confirm" targetRef="EndEvent_1" ns1:edgeClass="completion" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc38_custom_attributes_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc38_custom_attributes_E1" bpmnElement="tc38_custom_attributes_E1">
      <bpmndi:BPMNShape id="QHanaTask_Metadata_di" bpmnElement="QHanaTask_Metadata">
        <dc:Bounds x="170" y="168" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_Confirm_di" bpmnElement="UserTask_Confirm">
        <dc:Bounds x="440" y="168" width="190" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="710" y="190" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E1_di" bpmnElement="StartEvent_E1">
        <dc:Bounds x="90" y="190" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="360" y="208" />
        <di:waypoint x="440" y="208" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="630" y="208" />
        <di:waypoint x="710" y="208" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_start_di" bpmnElement="Flow_E1_start">
        <di:waypoint x="126" y="208" />
        <di:waypoint x="170" y="208" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>