<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" id="Definitions_tc34_lane_partial_removal" targetNamespace="http://qhana.example/testcases">
  <bpmn:collaboration id="Collaboration_tc34">
    <bpmn:participant id="Participant_1" name="Enterprise" processRef="tc34_lane_partial_removal_main" />
  </bpmn:collaboration>
  <bpmn:process id="tc34_lane_partial_removal_main" name="TC34 - Lane Partial Removal" isExecutable="true" camunda:versionTag="0.2">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_System" name="System Layer">
        <bpmn:flowNodeRef>AdHoc_E1_Wrapper</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AdHoc_E2_Wrapper</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Human" name="Human Layer">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AdHocSubProcess_ManualAction</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:adHocSubProcess id="AdHoc_E1_Wrapper" name="Extracted Fragment E1" qhana:fragmentRef="E1">
      <bpmn:startEvent id="StartEvent_AdHoc_E1_Wrapper">
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_in</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="ServiceTask_E1_Plugin" name="Extracted Fragment E1" camunda:type="external" camunda:topic="plugin-step.tc34_lane_partial_removal-E1">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_in</bpmn:incoming>
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_out</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="EndEvent_AdHoc_E1_Wrapper">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_out</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_in" sourceRef="StartEvent_AdHoc_E1_Wrapper" targetRef="ServiceTask_E1_Plugin" />
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_out" sourceRef="ServiceTask_E1_Plugin" targetRef="EndEvent_AdHoc_E1_Wrapper" />
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:adHocSubProcess id="AdHocSubProcess_ManualAction" name="Manual Action" ordering="Parallel">
      <qhana:qHAnaServiceTask id="QHanaTask_Review" name="review-data">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">review-data</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.reviewLog">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:adHocSubProcess id="AdHoc_E2_Wrapper" name="Extracted Fragment E2" qhana:fragmentRef="E2">
      <bpmn:startEvent id="StartEvent_AdHoc_E2_Wrapper">
        <bpmn:outgoing>Flow_AdHoc_E2_Wrapper_in</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="ServiceTask_E2_Plugin" name="Extracted Fragment E2" camunda:type="external" camunda:topic="plugin-step.tc34_lane_partial_removal-E2">
        <bpmn:incoming>Flow_AdHoc_E2_Wrapper_in</bpmn:incoming>
        <bpmn:outgoing>Flow_AdHoc_E2_Wrapper_out</bpmn:outgoing>
      </bpmn:serviceTask>
      <bpmn:endEvent id="EndEvent_AdHoc_E2_Wrapper">
        <bpmn:incoming>Flow_AdHoc_E2_Wrapper_out</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_AdHoc_E2_Wrapper_in" sourceRef="StartEvent_AdHoc_E2_Wrapper" targetRef="ServiceTask_E2_Plugin" />
      <bpmn:sequenceFlow id="Flow_AdHoc_E2_Wrapper_out" sourceRef="ServiceTask_E2_Plugin" targetRef="EndEvent_AdHoc_E2_Wrapper" />
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="AdHoc_E1_Wrapper" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="AdHoc_E1_Wrapper" targetRef="AdHocSubProcess_ManualAction" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="AdHocSubProcess_ManualAction" targetRef="AdHoc_E2_Wrapper" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="AdHoc_E2_Wrapper" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc34_lane_partial_removal_main">
    <bpmndi:BPMNPlane id="BPMNPlane_tc34_lane_partial_removal_main" bpmnElement="tc34_lane_partial_removal_main">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <omgdc:Bounds x="120" y="400" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AdHoc_E1_Wrapper_di" bpmnElement="AdHoc_E1_Wrapper" isExpanded="true">
        <omgdc:Bounds x="240" y="120" width="170" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AdHocSubProcess_ManualAction_di" bpmnElement="AdHocSubProcess_ManualAction" isExpanded="true">
        <omgdc:Bounds x="480" y="330" width="200" height="180" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="QHanaTask_Review_di" bpmnElement="QHanaTask_Review">
        <omgdc:Bounds x="505" y="380" width="150" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AdHoc_E2_Wrapper_di" bpmnElement="AdHoc_E2_Wrapper" isExpanded="true">
        <omgdc:Bounds x="740" y="120" width="170" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <omgdc:Bounds x="950" y="400" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <omgdi:waypoint x="151" y="400" />
        <omgdi:waypoint x="219" y="400" />
        <omgdi:waypoint x="219" y="220" />
        <omgdi:waypoint x="287" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <omgdi:waypoint x="376" y="220" />
        <omgdi:waypoint x="432" y="220" />
        <omgdi:waypoint x="432" y="330" />
        <omgdi:waypoint x="488" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <omgdi:waypoint x="668" y="330" />
        <omgdi:waypoint x="722" y="330" />
        <omgdi:waypoint x="722" y="220" />
        <omgdi:waypoint x="776" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <omgdi:waypoint x="853" y="220" />
        <omgdi:waypoint x="905" y="220" />
        <omgdi:waypoint x="905" y="400" />
        <omgdi:waypoint x="957" y="400" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>