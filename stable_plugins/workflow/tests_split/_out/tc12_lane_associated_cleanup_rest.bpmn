<?xml version='1.0' encoding='utf-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_TC12_LaneAssocCleanup" targetNamespace="http://qhana.example/testcases">

  <category id="Category_1">
    <categoryValue id="CategoryValue_1" value="review-group" />
  </category>

  <process id="tc12_lane_assoc_cleanup_rest" name="TC12 Lane + Association Cleanup (rest split)" isExecutable="true">
    <laneSet id="LaneSet_1"><lane id="Lane_REST" name="REST Lane">
        <flowNodeRef>UserTask_Input</flowNodeRef><flowNodeRef>ManualTask_Review</flowNodeRef></lane>
      </laneSet><startEvent id="StartEvent_1" name="Start">
      <outgoing>Flow_1</outgoing></startEvent>

    <manualTask id="ManualTask_Review" name="Manual Review (REST)">
      <outgoing>SplitFlow_tc12_lane_assoc_cleanup_rest_1</outgoing><incoming>Flow_2</incoming></manualTask>

    <userTask id="UserTask_Input" name="Input (REST)">
      <incoming>Flow_1</incoming><outgoing>Flow_2</outgoing></userTask>

    <endEvent id="EndEvent_1" name="End">
      <incoming>SplitFlow_tc12_lane_assoc_cleanup_rest_1</incoming></endEvent>

    <sequenceFlow id="SplitFlow_tc12_lane_assoc_cleanup_rest_1" sourceRef="ManualTask_Review" targetRef="EndEvent_1" /><sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="UserTask_Input" />
    <sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="ManualTask_Review" />
    <textAnnotation id="TextAnnotation_1">
      <text>Review note attached only to the manual task.</text>
    </textAnnotation>
    <dataObjectReference id="DataObjectRef_1" name="SharedInputRef" dataObjectRef="DataObject_1" />
    <association id="Assoc_Data_User" sourceRef="DataObjectRef_1" targetRef="UserTask_Input" />
    <association id="Assoc_Note_Manual" sourceRef="TextAnnotation_1" targetRef="ManualTask_Review" />
    </process>

  <collaboration id="Collab_1">
    <participant id="Participant_1" name="Main Participant" processRef="tc12_lane_assoc_cleanup_rest" />
  </collaboration>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collab_1">
      <bpmndi:BPMNShape id="Shape_StartEvent_1" bpmnElement="StartEvent_1">
        <omgdc:Bounds x="150" y="125" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_UserTask_Input" bpmnElement="UserTask_Input">
        <omgdc:Bounds x="240" y="103" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ManualTask_Review" bpmnElement="ManualTask_Review">
        <omgdc:Bounds x="400" y="103" width="110" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_1" bpmnElement="EndEvent_1">
        <omgdc:Bounds x="800" y="287" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_DataObjectRef_1" bpmnElement="DataObjectRef_1">
        <omgdc:Bounds x="250" y="20" width="36" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_TextAnnotation_1" bpmnElement="TextAnnotation_1">
        <omgdc:Bounds x="390" y="10" width="140" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Edge_Flow_1" bpmnElement="Flow_1">
        <omgdi:waypoint x="186" y="143" />
        <omgdi:waypoint x="240" y="143" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_2" bpmnElement="Flow_2">
        <omgdi:waypoint x="340" y="143" />
        <omgdi:waypoint x="400" y="143" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Assoc_Data_User" bpmnElement="Assoc_Data_User">
        <omgdi:waypoint x="268" y="70" />
        <omgdi:waypoint x="268" y="103" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Assoc_Note_Manual" bpmnElement="Assoc_Note_Manual">
        <omgdi:waypoint x="460" y="60" />
        <omgdi:waypoint x="455" y="103" />
      </bpmndi:BPMNEdge>
      </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</definitions>