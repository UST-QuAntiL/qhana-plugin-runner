<?xml version='1.0' encoding='utf-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_TC07_Artifacts" targetNamespace="http://qhana.example/testcases">

<process id="tc07_artifacts_rest" name="TC07 Artifacts + Associations (rest split)" isExecutable="true">
  <startEvent id="StartEvent_1" name="Start">
    <outgoing>Flow_1</outgoing></startEvent>

  <userTask id="UserTask_Input" name="Input (UserTask)">
    <incoming>Flow_1</incoming><outgoing>SplitFlow_tc07_artifacts_rest_2</outgoing></userTask>

  <endEvent id="EndEvent_1" name="End">
    <incoming>SplitFlow_tc07_artifacts_rest_2</incoming></endEvent>

  <sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="UserTask_Input" />
  <sequenceFlow id="SplitFlow_tc07_artifacts_rest_2" sourceRef="UserTask_Input" targetRef="EndEvent_1" /><dataObjectReference id="DataObjectRef_1" name="InputDataRef" dataObjectRef="DataObject_1" />
  <textAnnotation id="TextAnnotation_1">
    <text>This is a note attached to the input task.</text>
  </textAnnotation>

  <association id="Assoc_1" sourceRef="UserTask_Input" targetRef="TextAnnotation_1" />
  <association id="Assoc_2" sourceRef="UserTask_Input" targetRef="DataObjectRef_1" />
  </process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_tc07">
    <bpmndi:BPMNPlane id="BPMNPlane_tc07" bpmnElement="tc07_artifacts_rest">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <omgdc:Bounds x="150" y="120" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="UserTask_Input_di" bpmnElement="UserTask_Input">
        <omgdc:Bounds x="330" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <omgdc:Bounds x="690" y="120" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="TextAnnotation_1_di" bpmnElement="TextAnnotation_1">
        <omgdc:Bounds x="560" y="260" width="120" height="40" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <omgdi:waypoint x="0" y="0" /><omgdi:waypoint x="0" y="0" />
      </bpmndi:BPMNEdge>
      </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>