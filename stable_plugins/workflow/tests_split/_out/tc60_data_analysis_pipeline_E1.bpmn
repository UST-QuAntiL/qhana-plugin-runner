<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="sample-diagram" targetNamespace="http://bpmn.io/schema/bpmn" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd">
  <bpmn:process id="DataAnalysisPipeline_E1" name="Extracted Fragment E1" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="start_datasetType" label="Dataset Type" type="string" defaultValue="checkerboard" />
          <camunda:formField id="start_numPoints" label="Number of Points" type="string" defaultValue="100" />
          <camunda:formField id="start_dimensions" label="Dimensions" type="string" defaultValue="2" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_DataCreator" name="Data Creation" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qinput.datasetType">${start_datasetType}</camunda:inputParameter>
          <camunda:inputParameter name="qinput.numTrainPoints">${start_numPoints}</camunda:inputParameter>
          <camunda:inputParameter name="qinput.numTestPoints">${start_numPoints}</camunda:inputParameter>
          <camunda:inputParameter name="qhanaPlugin">data-creator</camunda:inputParameter>
          <camunda:inputParameter name="qhanaPluginVersion">v0.2.3</camunda:inputParameter>
          <camunda:inputParameter name="qhanaName">Data Creation</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.trainData">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_DataCreator_to_OneHot</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="Task_OneHotEncoding" name="One-Hot Encoding" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qinput.dataUrl">${qoutput.trainData}</camunda:inputParameter>
          <camunda:inputParameter name="qhanaPlugin">one-hot-encoding</camunda:inputParameter>
          <camunda:inputParameter name="qhanaPluginVersion">v0.2.1</camunda:inputParameter>
          <camunda:inputParameter name="qhanaName">One-Hot Encoding</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.encodedData">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_DataCreator_to_OneHot</bpmn:incoming>
      <bpmn:outgoing>Flow_E1_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_E1" name="End">
      <bpmn:incoming>Flow_E1_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_1" targetRef="Task_DataCreator" />
    <bpmn:sequenceFlow id="Flow_DataCreator_to_OneHot" sourceRef="Task_DataCreator" targetRef="Task_OneHotEncoding" />
    <bpmn:sequenceFlow id="Flow_E1_end" sourceRef="Task_OneHotEncoding" targetRef="EndEvent_E1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_DataAnalysisPipeline_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_DataAnalysisPipeline_E1" bpmnElement="DataAnalysisPipeline_E1">
      <bpmndi:BPMNShape id="Task_DataCreator_di" bpmnElement="Task_DataCreator">
        <dc:Bounds x="250" y="236" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_OneHotEncoding_di" bpmnElement="Task_OneHotEncoding">
        <dc:Bounds x="410" y="236" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="170" y="258" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_E1_di" bpmnElement="EndEvent_E1">
        <dc:Bounds x="560" y="258" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_DataCreator_to_OneHot_di" bpmnElement="Flow_DataCreator_to_OneHot">
        <di:waypoint x="350" y="276" />
        <di:waypoint x="410" y="276" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_start_di" bpmnElement="Flow_E1_start">
        <di:waypoint x="206" y="276" />
        <di:waypoint x="250" y="276" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_end_di" bpmnElement="Flow_E1_end">
        <di:waypoint x="510" y="276" />
        <di:waypoint x="560" y="276" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>