<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_tc11_xor_adhoc_inside_branch" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc11_xor_adhoc_inside_branch_main" name="TC11 - XOR Adhoc Inside Branch" isExecutable="true" camunda:versionTag="0.2" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:adHocSubProcess id="AdHoc_E1_Wrapper" name="Extracted Fragment E1" qhana:fragmentRef="E1">
      <bpmn:startEvent id="StartEvent_AdHoc_E1_Wrapper">
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_in</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="ServiceTask_E1_Plugin" name="Extracted Fragment E1" camunda:type="external" camunda:topic="plugin-step.tc11_xor_adhoc_inside_branch-E1">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_in</bpmn:incoming>
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_out</bpmn:outgoing>
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:outputParameter name="qoutput.contentUrl">${qoutput.contentUrl}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:endEvent id="EndEvent_AdHoc_E1_Wrapper">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_out</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_in" sourceRef="StartEvent_AdHoc_E1_Wrapper" targetRef="ServiceTask_E1_Plugin" />
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_out" sourceRef="ServiceTask_E1_Plugin" targetRef="EndEvent_AdHoc_E1_Wrapper" />
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:exclusiveGateway id="Gateway_Split" name="Content Filter Route" default="Flow_3B">
