<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_tc08_xor_exec_vs_adhoc" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc08_xor_exec_vs_adhoc_main" name="TC08 - XOR Exec vs Adhoc" isExecutable="true" camunda:versionTag="0.2" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:adHocSubProcess id="AdHoc_E1_Wrapper" name="Extracted Fragment E1" qhana:fragmentRef="E1">
      <bpmn:startEvent id="StartEvent_AdHoc_E1_Wrapper">
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_in</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="ServiceTask_E1_Plugin" name="Extracted Fragment E1" camunda:type="external" camunda:topic="plugin-step.tc08_xor_exec_vs_adhoc-E1">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_in</bpmn:incoming>
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_out</bpmn:outgoing>
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:outputParameter name="qoutput.applicationData">${qoutput.applicationData}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:endEvent id="EndEvent_AdHoc_E1_Wrapper">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_out</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_in" sourceRef="StartEvent_AdHoc_E1_Wrapper" targetRef="ServiceTask_E1_Plugin" />
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_out" sourceRef="ServiceTask_E1_Plugin" targetRef="EndEvent_AdHoc_E1_Wrapper" />
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:exclusiveGateway id="Gateway_Split" name="Determine Scoring Route" default="Flow_3B">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3A</bpmn:outgoing>
      <bpmn:outgoing>Flow_3B</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:adHocSubProcess id="AdHoc_E2_Wrapper" name="Extracted Fragment E2" qhana:fragmentRef="E2">
      <bpmn:startEvent id="StartEvent_AdHoc_E2_Wrapper">
        <bpmn:outgoing>Flow_AdHoc_E2_Wrapper_in</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="ServiceTask_E2_Plugin" name="Extracted Fragment E2" camunda:type="external" camunda:topic="plugin-step.tc08_xor_exec_vs_adhoc-E2">
        <bpmn:incoming>Flow_AdHoc_E2_Wrapper_in</bpmn:incoming>
        <bpmn:outgoing>Flow_AdHoc_E2_Wrapper_out</bpmn:outgoing>
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qoutput.applicationData">${qoutput.applicationData}</camunda:inputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:endEvent id="EndEvent_AdHoc_E2_Wrapper">
        <bpmn:incoming>Flow_AdHoc_E2_Wrapper_out</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_AdHoc_E2_Wrapper_in" sourceRef="StartEvent_AdHoc_E2_Wrapper" targetRef="ServiceTask_E2_Plugin" />
      <bpmn:sequenceFlow id="Flow_AdHoc_E2_Wrapper_out" sourceRef="ServiceTask_E2_Plugin" targetRef="EndEvent_AdHoc_E2_Wrapper" />
      <bpmn:incoming>Flow_3A</bpmn:incoming>
      <bpmn:outgoing>Flow_4A</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:adHocSubProcess id="AdHocSubProcess_Manual" name="Manual Risk Assessment" ordering="Parallel">
      <qhana:qHAnaServiceTask id="QHanaTask_ReviewDocs" name="review-documents">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">review-documents</camunda:inputParameter>
            <camunda:inputParameter name="qinput.data">${qoutput.applicationData}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.docReview">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
      <qhana:qHAnaServiceTask id="QHanaTask_ManualScore" name="assign-manual-score">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">assign-manual-score</camunda:inputParameter>
            <camunda:inputParameter name="qinput.review">${qoutput.docReview}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.manualScore">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
      <bpmn:incoming>Flow_3B</bpmn:incoming>
      <bpmn:outgoing>Flow_4B</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:exclusiveGateway id="Gateway_Merge" name="Merge Scoring">
      <bpmn:incoming>Flow_4A</bpmn:incoming>
      <bpmn:incoming>Flow_4B</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="AdHoc_E1_Wrapper" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="AdHoc_E1_Wrapper" targetRef="Gateway_Split" />
    <bpmn:sequenceFlow id="Flow_3A" name="Low Amount" sourceRef="Gateway_Split" targetRef="AdHoc_E2_Wrapper">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${amount &lt; 10000}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_3B" name="Default (High Amount)" sourceRef="Gateway_Split" targetRef="AdHocSubProcess_Manual" />
    <bpmn:sequenceFlow id="Flow_4A" sourceRef="AdHoc_E2_Wrapper" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_4B" sourceRef="AdHocSubProcess_Manual" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_Merge" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc08_xor_exec_vs_adhoc_main">
    <bpmndi:BPMNPlane id="BPMNPlane_tc08_xor_exec_vs_adhoc_main" bpmnElement="tc08_xor_exec_vs_adhoc_main">
