    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="Task_Exec" />
    <bpmn:sequenceFlow id="Flow_E1_end" sourceRef="Task_Exec" targetRef="EndEvent_E1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc42_no_dangling_nodes_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc42_no_dangling_nodes_E1" bpmnElement="tc42_no_dangling_nodes_E1">
      <bpmndi:BPMNShape id="Task_Exec_di" bpmnElement="Task_Exec">
        <dc:Bounds x="350" y="80" width="100" height="80" />
