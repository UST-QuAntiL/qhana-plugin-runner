<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" id="Definitions_tc28_data_object_cross_boundary" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc28_data_object_cross_boundary_E1" name="Extracted Fragment E1" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E1">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_Input" name="Input Terms">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.terms" label="Contract Terms" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <qhana:qHAnaServiceTask id="QHanaTask_DraftContract" name="draft-contract">
      <bpmn:dataOutputAssociation id="DataOutputAssociation_1">
        <bpmn:targetRef>DataObjectReference_Doc</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">draft-contract</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.terms}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.contractDoc">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_E1_end</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <bpmn:endEvent id="EndEvent_E1">
      <bpmn:incoming>Flow_E1_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="UserTask_Input" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="QHanaTask_DraftContract" />
    <bpmn:sequenceFlow id="Flow_E1_end" sourceRef="QHanaTask_DraftContract" targetRef="EndEvent_E1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc28_data_object_cross_boundary_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc28_data_object_cross_boundary_E1" bpmnElement="tc28_data_object_cross_boundary_E1">
      <bpmndi:BPMNShape id="UserTask_Input_di" bpmnElement="UserTask_Input">
        <dc:Bounds x="160" y="178" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="QHanaTask_DraftContract_di" bpmnElement="QHanaTask_DraftContract">
        <dc:Bounds x="390" y="178" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E1_di" bpmnElement="StartEvent_E1">
        <dc:Bounds x="80" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_E1_di" bpmnElement="EndEvent_E1">
        <dc:Bounds x="610" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="330" y="218" />
        <di:waypoint x="390" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_start_di" bpmnElement="Flow_E1_start">
        <di:waypoint x="116" y="218" />
        <di:waypoint x="160" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_end_di" bpmnElement="Flow_E1_end">
        <di:waypoint x="560" y="218" />
        <di:waypoint x="610" y="218" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>