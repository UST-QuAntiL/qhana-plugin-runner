<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_tc51_multiple_end_events" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc51_multiple_end_events_E2" name="Extracted Fragment E2" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E2">
      <bpmn:outgoing>Flow_E2_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="ServiceTask_Approve" name="approve-result" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">placeholder-approve</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.approvalId">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E2_start</bpmn:incoming>
      <bpmn:outgoing>Flow_E2_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_E2">
      <bpmn:incoming>Flow_E2_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E2_start" sourceRef="StartEvent_E2" targetRef="ServiceTask_Approve" />
    <bpmn:sequenceFlow id="Flow_E2_end" sourceRef="ServiceTask_Approve" targetRef="EndEvent_E2" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc51_multiple_end_events_E2">
    <bpmndi:BPMNPlane id="BPMNPlane_tc51_multiple_end_events_E2" bpmnElement="tc51_multiple_end_events_E2">
      <bpmndi:BPMNShape id="ServiceTask_Approve_di" bpmnElement="ServiceTask_Approve">
        <dc:Bounds x="440" y="80" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E2_di" bpmnElement="StartEvent_E2">
        <dc:Bounds x="360" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_E2_di" bpmnElement="EndEvent_E2">
        <dc:Bounds x="630" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_E2_start_di" bpmnElement="Flow_E2_start">
        <di:waypoint x="396" y="120" />
        <di:waypoint x="440" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E2_end_di" bpmnElement="Flow_E2_end">
        <di:waypoint x="580" y="120" />
        <di:waypoint x="630" y="120" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>