      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:adHocSubProcess id="AdHocSubProcess_2" name="Ad-hoc Validation Block" ordering="Parallel">
      <qhana:qHAnaServiceTask id="QHanaTask_Validate" name="validate-data">
