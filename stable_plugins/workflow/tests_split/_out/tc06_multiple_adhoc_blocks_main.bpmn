          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">approve-validation</camunda:inputParameter>
            <camunda:inputParameter name="qinput.data">${qoutput.validatedData}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.approvedValidation">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
      <bpmn:incoming>Flow_4</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:adHocSubProcess id="AdHoc_E3_Wrapper" name="Extracted Fragment E3" qhana:fragmentRef="E3">
      <bpmn:startEvent id="StartEvent_AdHoc_E3_Wrapper">
