        <bpmn:outgoing>Flow_AdHoc_E2_Wrapper_out</bpmn:outgoing>
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qoutput.annotatedData">${qoutput.annotatedData}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.transformedData">${qoutput.transformedData}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:endEvent id="EndEvent_AdHoc_E2_Wrapper">
        <bpmn:incoming>Flow_AdHoc_E2_Wrapper_out</bpmn:incoming>
