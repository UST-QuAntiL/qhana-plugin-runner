<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" id="Def_tc44" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc44_no_orphan_elements_E1" name="Extracted Fragment E1" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E1" name="Start">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <qhana:qHAnaServiceTask id="Task_Exec" name="Fragile Automated Process" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <bpmn:endEvent id="EndEvent_1" name="Success End">
      <bpmn:incoming>Flow_2</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:boundaryEvent id="BoundaryEvent_1" name="On Error" attachedToRef="Task_Exec">
      <bpmn:errorEventDefinition id="ErrorEventDefinition_1" />
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:boundaryEvent>
    <bpmn:endEvent id="EndEvent_Error" name="Error End">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="Task_Exec" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_Exec" targetRef="EndEvent_1" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="BoundaryEvent_1" targetRef="EndEvent_Error" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc44_no_orphan_elements_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc44_no_orphan_elements_E1" bpmnElement="tc44_no_orphan_elements_E1">
      <bpmndi:BPMNShape id="Task_Exec_di" bpmnElement="Task_Exec">
