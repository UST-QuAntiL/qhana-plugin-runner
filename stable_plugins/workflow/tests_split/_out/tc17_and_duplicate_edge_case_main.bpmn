  <bpmn:process id="tc17_and_duplicate_edge_case_main" name="TC17 - AND Duplicate Edge Case" isExecutable="true" camunda:versionTag="0.2" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_1" name="Start">
