<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_tc51_multiple_end_events" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc51_multiple_end_events_E1" name="Extracted Fragment E1" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E1" name="Start">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="ServiceTask_Check" name="check-input" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">placeholder-check</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.verdict">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_Split" name="Verdict" default="Flow_Reject">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_Approve</bpmn:outgoing>
      <bpmn:outgoing>Flow_Reject</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="ServiceTask_Approve" name="approve-result" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">placeholder-approve</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.approvalId">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Approve</bpmn:incoming>
      <bpmn:outgoing>Flow_To_Approved</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_Reject" name="record-rejection" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">placeholder-reject</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.rejectionCode">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_Reject</bpmn:incoming>
      <bpmn:outgoing>Flow_To_Rejected</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_Approved" name="Approved">
      <bpmn:incoming>Flow_To_Approved</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:endEvent id="EndEvent_Rejected" name="Rejected">
      <bpmn:incoming>Flow_To_Rejected</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="ServiceTask_Check" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="ServiceTask_Check" targetRef="Gateway_Split" />
    <bpmn:sequenceFlow id="Flow_Approve" sourceRef="Gateway_Split" targetRef="ServiceTask_Approve">
      <bpmn:conditionExpression>${qoutput.verdict == 'approve'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_Reject" sourceRef="Gateway_Split" targetRef="ServiceTask_Reject" />
    <bpmn:sequenceFlow id="Flow_To_Approved" sourceRef="ServiceTask_Approve" targetRef="EndEvent_Approved" />
    <bpmn:sequenceFlow id="Flow_To_Rejected" sourceRef="ServiceTask_Reject" targetRef="EndEvent_Rejected" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc51_multiple_end_events_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc51_multiple_end_events_E1" bpmnElement="tc51_multiple_end_events_E1">
      <bpmndi:BPMNShape id="ServiceTask_Check_di" bpmnElement="ServiceTask_Check">
        <dc:Bounds x="160" y="198" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Split_di" bpmnElement="Gateway_Split">
        <dc:Bounds x="340" y="213" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_Approve_di" bpmnElement="ServiceTask_Approve">
        <dc:Bounds x="440" y="80" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_Reject_di" bpmnElement="ServiceTask_Reject">
        <dc:Bounds x="440" y="320" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Approved_di" bpmnElement="EndEvent_Approved">
        <dc:Bounds x="620" y="102" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_Rejected_di" bpmnElement="EndEvent_Rejected">
        <dc:Bounds x="620" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E1_di" bpmnElement="StartEvent_E1">
        <dc:Bounds x="80" y="220" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="300" y="238" />
        <di:waypoint x="340" y="238" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Approve_di" bpmnElement="Flow_Approve">
        <di:waypoint x="365" y="213" />
        <di:waypoint x="365" y="120" />
        <di:waypoint x="440" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Reject_di" bpmnElement="Flow_Reject">
        <di:waypoint x="365" y="263" />
        <di:waypoint x="365" y="360" />
        <di:waypoint x="440" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_To_Approved_di" bpmnElement="Flow_To_Approved">
        <di:waypoint x="580" y="120" />
        <di:waypoint x="620" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_To_Rejected_di" bpmnElement="Flow_To_Rejected">
        <di:waypoint x="580" y="360" />
        <di:waypoint x="620" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_start_di" bpmnElement="Flow_E1_start">
        <di:waypoint x="116" y="238" />
        <di:waypoint x="160" y="238" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>