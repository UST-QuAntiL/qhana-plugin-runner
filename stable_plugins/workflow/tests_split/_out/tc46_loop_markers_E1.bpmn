<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_tc46_loop_markers" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc46_loop_markers_E1" name="Extracted Fragment E1" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E1">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="ServiceTask_Prepare" name="prepare-batch" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">placeholder-prepare-batch</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.batchItems">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_Loop" name="process-each-item" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">placeholder-process-item</camunda:inputParameter>
          <camunda:inputParameter name="qinput.item">${qoutput.batchItems}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.itemResult">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:multiInstanceLoopCharacteristics isSequential="false" camunda:collection="${qoutput.batchItems}" camunda:elementVariable="item">
        <bpmn:loopCardinality>10</bpmn:loopCardinality>
      </bpmn:multiInstanceLoopCharacteristics>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="ServiceTask_Aggregate" name="aggregate-results" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">placeholder-aggregate</camunda:inputParameter>
          <camunda:inputParameter name="qinput.results">${qoutput.itemResult}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.aggregated">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:standardLoopCharacteristics testBefore="true">
        <bpmn:loopCondition>${retries &lt; 3}</bpmn:loopCondition>
      </bpmn:standardLoopCharacteristics>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_E1_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_E1">
      <bpmn:incoming>Flow_E1_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="ServiceTask_Prepare" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="ServiceTask_Prepare" targetRef="ServiceTask_Loop" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="ServiceTask_Loop" targetRef="ServiceTask_Aggregate" />
    <bpmn:sequenceFlow id="Flow_E1_end" sourceRef="ServiceTask_Aggregate" targetRef="EndEvent_E1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc46_loop_markers_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc46_loop_markers_E1" bpmnElement="tc46_loop_markers_E1">
      <bpmndi:BPMNShape id="ServiceTask_Prepare_di" bpmnElement="ServiceTask_Prepare">
        <dc:Bounds x="160" y="178" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_Loop_di" bpmnElement="ServiceTask_Loop">
        <dc:Bounds x="340" y="178" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="ServiceTask_Aggregate_di" bpmnElement="ServiceTask_Aggregate">
        <dc:Bounds x="520" y="178" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E1_di" bpmnElement="StartEvent_E1">
        <dc:Bounds x="80" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_E1_di" bpmnElement="EndEvent_E1">
        <dc:Bounds x="710" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="300" y="218" />
        <di:waypoint x="340" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="480" y="218" />
        <di:waypoint x="520" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_start_di" bpmnElement="Flow_E1_start">
        <di:waypoint x="116" y="218" />
        <di:waypoint x="160" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_end_di" bpmnElement="Flow_E1_end">
        <di:waypoint x="660" y="218" />
        <di:waypoint x="710" y="218" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>