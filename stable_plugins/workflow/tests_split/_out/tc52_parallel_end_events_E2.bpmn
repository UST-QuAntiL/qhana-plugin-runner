<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_tc52_parallel_end_events" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc52_parallel_end_events_E2" name="Extracted Fragment E2" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E2">
      <bpmn:outgoing>Flow_E2_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="ServiceTask_ArchiveB" name="archive-stream-b" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">placeholder-archive-b</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.archiveB">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E2_start</bpmn:incoming>
      <bpmn:outgoing>Flow_E2_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_E2">
      <bpmn:incoming>Flow_E2_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E2_start" sourceRef="StartEvent_E2" targetRef="ServiceTask_ArchiveB" />
    <bpmn:sequenceFlow id="Flow_E2_end" sourceRef="ServiceTask_ArchiveB" targetRef="EndEvent_E2" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc52_parallel_end_events_E2">
    <bpmndi:BPMNPlane id="BPMNPlane_tc52_parallel_end_events_E2" bpmnElement="tc52_parallel_end_events_E2">
      <bpmndi:BPMNShape id="ServiceTask_ArchiveB_di" bpmnElement="ServiceTask_ArchiveB">
        <dc:Bounds x="270" y="320" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E2_di" bpmnElement="StartEvent_E2">
