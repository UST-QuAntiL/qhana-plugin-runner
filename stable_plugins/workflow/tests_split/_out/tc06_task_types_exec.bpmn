<?xml version='1.0' encoding='utf-8'?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_TC06_TaskTypes" targetNamespace="http://qhana.example/testcases">

<process id="tc06_task_types_exec" name="TC06 Task Types (exec split)" isExecutable="true">
  <startEvent id="StartEvent_1" name="Start">
    <outgoing>SplitFlow_tc06_task_types_exec_2</outgoing></startEvent>

  <serviceTask id="QHanaTask_HelloWorld" name="HelloWorld (QHAna)" camunda:type="external" camunda:topic="qhana-task">
    <extensionElements>
      <camunda:inputOutput>
        <camunda:inputParameter name="dummy">1</camunda:inputParameter>
      </camunda:inputOutput>
    </extensionElements>
  <outgoing>Flow_8</outgoing><incoming>SplitFlow_tc06_task_types_exec_2</incoming></serviceTask>

  <endEvent id="EndEvent_1" name="End">
    <incoming>Flow_8</incoming></endEvent>

  <sequenceFlow id="Flow_8" sourceRef="QHanaTask_HelloWorld" targetRef="EndEvent_1" />
<sequenceFlow id="SplitFlow_tc06_task_types_exec_2" sourceRef="StartEvent_1" targetRef="QHanaTask_HelloWorld" /></process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_tc06">
    <bpmndi:BPMNPlane id="BPMNPlane_tc06" bpmnElement="tc06_task_types_exec">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <omgdc:Bounds x="150" y="120" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="QHanaTask_HelloWorld_di" bpmnElement="QHanaTask_HelloWorld">
        <omgdc:Bounds x="1130" y="120" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <omgdc:Bounds x="1270" y="120" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_8_di" bpmnElement="Flow_8">
        <omgdi:waypoint x="0" y="0" /><omgdi:waypoint x="0" y="0" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</definitions>