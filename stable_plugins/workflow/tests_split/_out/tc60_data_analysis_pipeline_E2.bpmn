<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="sample-diagram" targetNamespace="http://bpmn.io/schema/bpmn" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd">
  <bpmn:process id="DataAnalysisPipeline_E2" name="Extracted Fragment E2" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_E2" name="Start">
      <bpmn:outgoing>Flow_E2_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_KMeans" name="K-Means Clustering" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qinput.dataUrl">${qoutput.encodedData}</camunda:inputParameter>
          <camunda:inputParameter name="qinput.k">4</camunda:inputParameter>
          <camunda:inputParameter name="qhanaPlugin">classical-k-means</camunda:inputParameter>
          <camunda:inputParameter name="qhanaPluginVersion">v0.1.1</camunda:inputParameter>
          <camunda:inputParameter name="qhanaName">K-Means Clustering</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.clusters">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E2_start</bpmn:incoming>
      <bpmn:outgoing>Flow_E2_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_E2" name="End">
      <bpmn:incoming>Flow_E2_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E2_start" sourceRef="StartEvent_E2" targetRef="Task_KMeans" />
    <bpmn:sequenceFlow id="Flow_E2_end" sourceRef="Task_KMeans" targetRef="EndEvent_E2" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_DataAnalysisPipeline_E2">
    <bpmndi:BPMNPlane id="BPMNPlane_DataAnalysisPipeline_E2" bpmnElement="DataAnalysisPipeline_E2">
      <bpmndi:BPMNShape id="Task_KMeans_di" bpmnElement="Task_KMeans">
        <dc:Bounds x="1040" y="160" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E2_di" bpmnElement="StartEvent_E2">
        <dc:Bounds x="960" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_E2_di" bpmnElement="EndEvent_E2">
        <dc:Bounds x="1190" y="182" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_E2_start_di" bpmnElement="Flow_E2_start">
        <di:waypoint x="996" y="200" />
        <di:waypoint x="1040" y="200" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E2_end_di" bpmnElement="Flow_E2_end">
        <di:waypoint x="1140" y="200" />
        <di:waypoint x="1190" y="200" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>