<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="Definitions_tc07_xor_exec_vs_exec" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc07_xor_exec_vs_exec_E1" name="Extracted Fragment E1" isExecutable="true" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_E1" name="Start">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="UserTask_Input" name="Enter Input Text">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.inputText" label="Input Text" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_Split" name="Choose Language (XOR)" default="Flow_3B">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3A</bpmn:outgoing>
      <bpmn:outgoing>Flow_3B</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <qhana:qHAnaServiceTask id="QHanaTask_TranslateFR" name="translate-french">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">translate-french</camunda:inputParameter>
          <camunda:inputParameter name="qinput.text">${qoutput.inputText}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.translatedText">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3A</bpmn:incoming>
      <bpmn:outgoing>Flow_4A</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <qhana:qHAnaServiceTask id="QHanaTask_TranslateES" name="translate-spanish">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">translate-spanish</camunda:inputParameter>
          <camunda:inputParameter name="qinput.text">${qoutput.inputText}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.translatedText">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3B</bpmn:incoming>
      <bpmn:outgoing>Flow_4B</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <bpmn:exclusiveGateway id="Gateway_Merge" name="Merge Translations">
      <bpmn:incoming>Flow_4A</bpmn:incoming>
      <bpmn:incoming>Flow_4B</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="UserTask_Input" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="Gateway_Split" />
    <bpmn:sequenceFlow id="Flow_3A" name="If French" sourceRef="Gateway_Split" targetRef="QHanaTask_TranslateFR">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${language == 'FR'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_3B" name="Default (Spanish)" sourceRef="Gateway_Split" targetRef="QHanaTask_TranslateES" />
    <bpmn:sequenceFlow id="Flow_4A" sourceRef="QHanaTask_TranslateFR" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_4B" sourceRef="QHanaTask_TranslateES" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_Merge" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc07_xor_exec_vs_exec_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc07_xor_exec_vs_exec_E1" bpmnElement="tc07_xor_exec_vs_exec_E1">
      <bpmndi:BPMNShape id="UserTask_Input_di" bpmnElement="UserTask_Input">
        <dc:Bounds x="160" y="178" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Split_di" bpmnElement="Gateway_Split" isMarkerVisible="true">
        <dc:Bounds x="390" y="193" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="375" y="160" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="QHanaTask_TranslateFR_di" bpmnElement="QHanaTask_TranslateFR">
        <dc:Bounds x="550" y="80" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="QHanaTask_TranslateES_di" bpmnElement="QHanaTask_TranslateES">
        <dc:Bounds x="550" y="280" width="170" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_Merge_di" bpmnElement="Gateway_Merge" isMarkerVisible="true">
        <dc:Bounds x="810" y="193" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="805" y="250" width="60" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="920" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E1_di" bpmnElement="StartEvent_E1">
        <dc:Bounds x="80" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="330" y="218" />
        <di:waypoint x="390" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3A_di" bpmnElement="Flow_3A">
        <di:waypoint x="415" y="193" />
        <di:waypoint x="415" y="120" />
        <di:waypoint x="550" y="120" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="440" y="100" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3B_di" bpmnElement="Flow_3B">
        <di:waypoint x="415" y="243" />
        <di:waypoint x="415" y="320" />
        <di:waypoint x="550" y="320" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="440" y="330" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4A_di" bpmnElement="Flow_4A">
        <di:waypoint x="720" y="120" />
        <di:waypoint x="835" y="120" />
        <di:waypoint x="835" y="193" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4B_di" bpmnElement="Flow_4B">
        <di:waypoint x="720" y="320" />
        <di:waypoint x="835" y="320" />
        <di:waypoint x="835" y="243" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="860" y="218" />
        <di:waypoint x="920" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E1_start_di" bpmnElement="Flow_E1_start">
        <di:waypoint x="116" y="218" />
        <di:waypoint x="160" y="218" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>