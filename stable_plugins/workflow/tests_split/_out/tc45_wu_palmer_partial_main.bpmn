<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" id="sample-diagram" targetNamespace="http://bpmn.io/schema/bpmn" xsi:schemaLocation="http://www.omg.org/spec/BPMN/20100524/MODEL BPMN20.xsd">
  <bpmn:process id="Wu_Palmer_Mixed_main" name="Wu Palmer Pipeline (Mixed Adhoc)" isExecutable="true" camunda:versionTag="v1.4" camunda:historyTimeToLive="360000">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="start_entitiesUrl" label="Entities URL" type="string" defaultValue="file_url:: entity/*, text/csv" />
          <camunda:formField id="start_entitiesMetadataUrl" label="Attribute Metadata URL" type="string" defaultValue="file_url:: entity/attribute-metadata, application/json" />
          <camunda:formField id="start_taxonomiesZipUrl" label="Taxonomies URL" type="string" defaultValue="file_url:: graph/taxonomy, application/zip" />
          <camunda:formField id="start_attributes" label="Attributes (1 Attribute per Line)" type="string" />
          <camunda:formField id="start_mdsDimensions" label="Nr. of Dimensions for MDS" type="string" defaultValue="2" />
          <camunda:formField id="start_mdsMaxIter" label="Max Iterations for MDS" type="string" defaultValue="300" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:outgoing>Flow_05mvkgh</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:adHocSubProcess id="AdHoc_E1_Wrapper" name="Extracted Fragment E1" qhana:fragmentRef="E1">
      <bpmn:startEvent id="StartEvent_AdHoc_E1_Wrapper">
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_in</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="ServiceTask_E1_Plugin" name="Extracted Fragment E1" camunda:type="external" camunda:topic="plugin-step.Wu_Palmer_Mixed-E1">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_in</bpmn:incoming>
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_out</bpmn:outgoing>
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="start_attributes">${start_attributes}</camunda:inputParameter>
            <camunda:inputParameter name="start_entitiesMetadataUrl">${start_entitiesMetadataUrl}</camunda:inputParameter>
            <camunda:inputParameter name="start_entitiesUrl">${start_entitiesUrl}</camunda:inputParameter>
            <camunda:inputParameter name="start_mdsDimensions">${start_mdsDimensions}</camunda:inputParameter>
            <camunda:inputParameter name="start_taxonomiesZipUrl">${start_taxonomiesZipUrl}</camunda:inputParameter>
            <camunda:outputParameter name="return.qoutput.mds">${return.qoutput.mds}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:endEvent id="EndEvent_AdHoc_E1_Wrapper">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_out</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_in" sourceRef="StartEvent_AdHoc_E1_Wrapper" targetRef="ServiceTask_E1_Plugin" />
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_out" sourceRef="ServiceTask_E1_Plugin" targetRef="EndEvent_AdHoc_E1_Wrapper" />
      <bpmn:incoming>Flow_05mvkgh</bpmn:incoming>
      <bpmn:outgoing>Flow_To_AdHoc</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:adHocSubProcess id="Activity_AdHocCluster" name="Interactive Clustering Analysis" ordering="Parallel">
      <bpmn:serviceTask id="Activity_KMeans" name="K-Means Clustering" camunda:type="external" camunda:topic="qhana-task">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qinput.mdsPoints">${return.qoutput.mds}</camunda:inputParameter>
            <camunda:inputParameter name="qhanaPlugin">k-means</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.clusters">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:serviceTask id="Activity_HumanReview" name="Clustered Scatter Plot Visualization" camunda:type="external" camunda:topic="plugin.cluster-scatter-visualization">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaPlugin">cluster-scatter-visualization</camunda:inputParameter>
            <camunda:inputParameter name="qhanaPluginVersion">v1-0-0</camunda:inputParameter>
            <camunda:inputParameter name="qhanaName">Clustered Scatter Plot Visualization</camunda:inputParameter>
            <camunda:inputParameter name="qinput.entityPointsUrl">${return.qoutput.mds}</camunda:inputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:incoming>Flow_To_AdHoc</bpmn:incoming>
      <bpmn:outgoing>Flow_To_End</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:endEvent id="Event_0ck8ig8" name="End">
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="end_clustersUrl" label="Clusters URL" type="string" defaultValue="file_url:: graph/clusters, application/json" />
        </camunda:formData>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_To_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_05mvkgh" sourceRef="StartEvent_1" targetRef="AdHoc_E1_Wrapper" />
    <bpmn:sequenceFlow id="Flow_To_AdHoc" sourceRef="AdHoc_E1_Wrapper" targetRef="Activity_AdHocCluster" />
    <bpmn:sequenceFlow id="Flow_To_End" sourceRef="Activity_AdHocCluster" targetRef="Event_0ck8ig8" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_Wu_Palmer_Mixed_main">
    <bpmndi:BPMNPlane id="BPMNPlane_Wu_Palmer_Mixed_main" bpmnElement="Wu_Palmer_Mixed_main">
      <bpmndi:BPMNShape id="BPMNShape_StartEvent_1" bpmnElement="StartEvent_1">
        <dc:Bounds x="150" y="240" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AdHoc_E1_Wrapper_di" bpmnElement="AdHoc_E1_Wrapper" isExpanded="true">
        <dc:Bounds x="240" y="208" width="760" height="100" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_AdHocCluster_di" bpmnElement="Activity_AdHocCluster" isExpanded="true">
        <dc:Bounds x="1050" y="150" width="300" height="200" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_KMeans_di" bpmnElement="Activity_KMeans">
        <dc:Bounds x="1080" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Activity_HumanReview_di" bpmnElement="Activity_HumanReview">
        <dc:Bounds x="1220" y="200" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Event_0ck8ig8_di" bpmnElement="Event_0ck8ig8">
        <dc:Bounds x="1420" y="240" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_05mvkgh_di" bpmnElement="Flow_05mvkgh">
        <di:waypoint x="186" y="258" />
        <di:waypoint x="240" y="258" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_To_AdHoc_di" bpmnElement="Flow_To_AdHoc">
        <di:waypoint x="1000" y="252" />
        <di:waypoint x="1050" y="252" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_To_End_di" bpmnElement="Flow_To_End">
        <di:waypoint x="1350" y="258" />
        <di:waypoint x="1420" y="258" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>