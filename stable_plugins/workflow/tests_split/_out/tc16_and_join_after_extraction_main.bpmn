<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" id="Definitions_tc16_and_join_after_extraction" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc16_and_join_after_extraction_main" name="TC16 - AND Join After Extraction" isExecutable="true" camunda:versionTag="0.2" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:adHocSubProcess id="AdHoc_E1_Wrapper" name="Extracted Fragment E1" qhana:fragmentRef="E1">
      <bpmn:startEvent id="StartEvent_AdHoc_E1_Wrapper">
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_in</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="ServiceTask_E1_Plugin" name="Extracted Fragment E1" camunda:type="external" camunda:topic="plugin-step.tc16_and_join_after_extraction-E1">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_in</bpmn:incoming>
        <bpmn:outgoing>Flow_AdHoc_E1_Wrapper_out</bpmn:outgoing>
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:outputParameter name="qoutput.architectureData">${qoutput.architectureData}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:endEvent id="EndEvent_AdHoc_E1_Wrapper">
        <bpmn:incoming>Flow_AdHoc_E1_Wrapper_out</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_in" sourceRef="StartEvent_AdHoc_E1_Wrapper" targetRef="ServiceTask_E1_Plugin" />
      <bpmn:sequenceFlow id="Flow_AdHoc_E1_Wrapper_out" sourceRef="ServiceTask_E1_Plugin" targetRef="EndEvent_AdHoc_E1_Wrapper" />
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:parallelGateway id="Gateway_Split" name="Parallel Audit Route">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3A</bpmn:outgoing>
      <bpmn:outgoing>Flow_3B</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:adHocSubProcess id="AdHoc_E2_Wrapper" name="Extracted Fragment E2" qhana:fragmentRef="E2">
      <bpmn:startEvent id="StartEvent_AdHoc_E2_Wrapper">
        <bpmn:outgoing>Flow_AdHoc_E2_Wrapper_in</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="ServiceTask_E2_Plugin" name="Extracted Fragment E2" camunda:type="external" camunda:topic="plugin-step.tc16_and_join_after_extraction-E2">
        <bpmn:incoming>Flow_AdHoc_E2_Wrapper_in</bpmn:incoming>
        <bpmn:outgoing>Flow_AdHoc_E2_Wrapper_out</bpmn:outgoing>
        <bpmn:extensionElements>
