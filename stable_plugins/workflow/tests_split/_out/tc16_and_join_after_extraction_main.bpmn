            <camunda:inputParameter name="qoutput.diagramReview">${qoutput.diagramReview}</camunda:inputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:endEvent id="EndEvent_AdHoc_E3_Wrapper">
        <bpmn:incoming>Flow_AdHoc_E3_Wrapper_out</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Flow_AdHoc_E3_Wrapper_in" sourceRef="StartEvent_AdHoc_E3_Wrapper" targetRef="ServiceTask_E3_Plugin" />
      <bpmn:sequenceFlow id="Flow_AdHoc_E3_Wrapper_out" sourceRef="ServiceTask_E3_Plugin" targetRef="EndEvent_AdHoc_E3_Wrapper" />
      <bpmn:incoming>Flow_4B</bpmn:incoming>
      <bpmn:outgoing>Flow_5B</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:parallelGateway id="Gateway_Merge" name="Join Audit Streams">
      <bpmn:incoming>Flow_4A</bpmn:incoming>
      <bpmn:incoming>Flow_5B</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:parallelGateway>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_6</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="AdHoc_E1_Wrapper" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="AdHoc_E1_Wrapper" targetRef="Gateway_Split" />
    <bpmn:sequenceFlow id="Flow_3A" name="Automated Path" sourceRef="Gateway_Split" targetRef="AdHoc_E2_Wrapper" />
    <bpmn:sequenceFlow id="Flow_4A" sourceRef="AdHoc_E2_Wrapper" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_3B" name="Manual Path" sourceRef="Gateway_Split" targetRef="AdHocSubProcess_ManualReview" />
    <bpmn:sequenceFlow id="Flow_4B" sourceRef="AdHocSubProcess_ManualReview" targetRef="AdHoc_E3_Wrapper" />
    <bpmn:sequenceFlow id="Flow_5B" sourceRef="AdHoc_E3_Wrapper" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Gateway_Merge" targetRef="EndEvent_1" />
  </bpmn:process>
