        <di:waypoint x="370" y="232" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="800" y="231" />
        <di:waypoint x="860" y="233" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Association_1_di" bpmnElement="Association_1">
        <di:waypoint x="226" y="120" />
        <di:waypoint x="221" y="120" />
        <di:waypoint x="221" y="188" />
        <di:waypoint x="216" y="188" />
