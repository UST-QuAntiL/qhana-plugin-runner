<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" id="Definitions_tc36_di_cleanup" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc36_di_cleanup_main" name="TC36 - DI cleanup" isExecutable="true" camunda:versionTag="0.2" camunda:historyTimeToLive="180">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:adHocSubProcess id="AdHoc_E1_Wrapper" name="Extracted Fragment E1" qhana:fragmentRef="E1">
      <bpmn:serviceTask id="ServiceTask_E1_Plugin" name="Extracted Fragment E1" camunda:type="external" camunda:topic="plugin.tc36_di_cleanup_E1">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:outputParameter name="qoutput.prepared">${qoutput.prepared}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:adHocSubProcess id="AdHocSubProcess_1" name="Ad-hoc Review Block" ordering="Parallel">
      <qhana:qHAnaServiceTask id="QHanaTask_Check" name="check-data">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">check-data</camunda:inputParameter>
            <camunda:inputParameter name="qinput.data">${qoutput.prepared}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.checked">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
      <qhana:qHAnaServiceTask id="QHanaTask_Approve" name="approve-data">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">approve-data</camunda:inputParameter>
            <camunda:inputParameter name="qinput.data">${qoutput.checked}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.approved">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:adHocSubProcess id="AdHoc_E2_Wrapper" name="Extracted Fragment E2" qhana:fragmentRef="E2">
      <bpmn:serviceTask id="ServiceTask_E2_Plugin" name="Extracted Fragment E2" camunda:type="external" camunda:topic="plugin.tc36_di_cleanup_E2">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qoutput.approved">${qoutput.approved}</camunda:inputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_to_Main_End</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="AdHoc_E1_Wrapper" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="AdHoc_E1_Wrapper" targetRef="AdHocSubProcess_1" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="AdHocSubProcess_1" targetRef="AdHoc_E2_Wrapper" />
    <bpmn:endEvent id="EndEvent_Main" name="End">
      <bpmn:incoming>Flow_to_Main_End</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_to_Main_End" sourceRef="AdHoc_E2_Wrapper" targetRef="EndEvent_Main" />
    <bpmn:textAnnotation id="TextAnnotation_1">
      <bpmn:text>Annotation linked to removable/extractable area</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_1" sourceRef="TextAnnotation_1" targetRef="AdHoc_E1_Wrapper" />
    <bpmn:association id="Association_2" sourceRef="TextAnnotation_1" targetRef="AdHocSubProcess_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc36_di_cleanup_main">
    <bpmndi:BPMNPlane id="BPMNPlane_tc36_di_cleanup_main" bpmnElement="tc36_di_cleanup_main">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
