<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_tc51_multiple_end_events" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc51_multiple_end_events_E3" name="Extracted Fragment E3" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E3">
      <bpmn:outgoing>Flow_E3_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="ServiceTask_Reject" name="record-rejection" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">placeholder-reject</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.rejectionCode">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E3_start</bpmn:incoming>
      <bpmn:outgoing>Flow_E3_end</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_E3">
      <bpmn:incoming>Flow_E3_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E3_start" sourceRef="StartEvent_E3" targetRef="ServiceTask_Reject" />
    <bpmn:sequenceFlow id="Flow_E3_end" sourceRef="ServiceTask_Reject" targetRef="EndEvent_E3" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc51_multiple_end_events_E3">
    <bpmndi:BPMNPlane id="BPMNPlane_tc51_multiple_end_events_E3" bpmnElement="tc51_multiple_end_events_E3">
      <bpmndi:BPMNShape id="ServiceTask_Reject_di" bpmnElement="ServiceTask_Reject">
        <dc:Bounds x="440" y="320" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="StartEvent_E3_di" bpmnElement="StartEvent_E3">
        <dc:Bounds x="360" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_E3_di" bpmnElement="EndEvent_E3">
        <dc:Bounds x="630" y="342" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_E3_start_di" bpmnElement="Flow_E3_start">
        <di:waypoint x="396" y="360" />
        <di:waypoint x="440" y="360" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_E3_end_di" bpmnElement="Flow_E3_end">
        <di:waypoint x="580" y="360" />
        <di:waypoint x="630" y="360" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>