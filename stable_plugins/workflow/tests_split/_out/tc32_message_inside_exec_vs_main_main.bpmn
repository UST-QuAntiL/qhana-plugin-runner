            <camunda:inputParameter name="qhanaName">approve-update</camunda:inputParameter>
            <camunda:inputParameter name="qinput.payload">${qoutput.reviewedUpdate}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.approvedUpdate">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:adHocSubProcess>
    <bpmn:adHocSubProcess id="AdHoc_E2_Wrapper" name="Extracted Fragment E2" qhana:fragmentRef="E2">
