<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:qhana="https://github.com/qhana" id="Definitions_tc02_exec_after_adhoc" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc02_exec_after_adhoc_E1" name="Extracted Fragment E1" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E1" name="Start">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <qhana:qHAnaServiceTask id="QHanaTask_Process" name="process-tagged-text">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">process-tagged-text</camunda:inputParameter>
          <camunda:inputParameter name="qinput.text">${qoutput.filteredText}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.processedText">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <qhana:qHAnaServiceTask id="QHanaTask_Summarize" name="summarize-text">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">summarize-text</camunda:inputParameter>
          <camunda:inputParameter name="qinput.text">${qoutput.processedText}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.summary">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </qhana:qHAnaServiceTask>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="QHanaTask_Process" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="QHanaTask_Process" targetRef="QHanaTask_Summarize" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="QHanaTask_Summarize" targetRef="EndEvent_1" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_tc02_exec_after_adhoc_E1">
    <bpmndi:BPMNPlane id="BPMNPlane_tc02_exec_after_adhoc_E1" bpmnElement="tc02_exec_after_adhoc_E1">
      <bpmndi:BPMNShape id="QHanaTask_Process_di" bpmnElement="QHanaTask_Process">
        <dc:Bounds x="670" y="168" width="180" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="QHanaTask_Summarize_di" bpmnElement="QHanaTask_Summarize">
        <dc:Bounds x="910" y="168" width="180" height="80" />
