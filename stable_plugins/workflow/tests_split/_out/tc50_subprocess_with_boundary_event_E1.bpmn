<?xml version='1.0' encoding='utf-8'?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:camunda="http://camunda.org/schema/1.0/bpmn" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_tc50_subprocess_with_boundary_event" targetNamespace="http://qhana.example/testcases">
  <bpmn:process id="tc50_subprocess_with_boundary_event_E1" name="Extracted Fragment E1" isExecutable="true">
    <bpmn:startEvent id="StartEvent_E1" name="Start">
      <bpmn:outgoing>Flow_E1_start</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:subProcess id="SubProcess_WithBoundary" name="Subprocess with Boundary Event">
      <bpmn:startEvent id="Inner_Start">
        <bpmn:outgoing>Inner_Flow_1</bpmn:outgoing>
      </bpmn:startEvent>
      <bpmn:serviceTask id="Inner_LongRunning" name="long-running-task" camunda:type="external" camunda:topic="qhana-task">
        <bpmn:incoming>Inner_Flow_1</bpmn:incoming>
        <bpmn:outgoing>Inner_Flow_2</bpmn:outgoing>
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaPlugin">placeholder-long-running</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.result">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
      <bpmn:boundaryEvent id="Inner_TimerBoundary" attachedToRef="Inner_LongRunning">
        <bpmn:outgoing>Inner_Flow_Timeout</bpmn:outgoing>
        <bpmn:timerEventDefinition>
          <bpmn:timeDuration>PT30M</bpmn:timeDuration>
        </bpmn:timerEventDefinition>
      </bpmn:boundaryEvent>
      <bpmn:endEvent id="Inner_End">
        <bpmn:incoming>Inner_Flow_2</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:endEvent id="Inner_TimeoutEnd">
        <bpmn:incoming>Inner_Flow_Timeout</bpmn:incoming>
      </bpmn:endEvent>
      <bpmn:sequenceFlow id="Inner_Flow_1" sourceRef="Inner_Start" targetRef="Inner_LongRunning" />
      <bpmn:sequenceFlow id="Inner_Flow_2" sourceRef="Inner_LongRunning" targetRef="Inner_End" />
      <bpmn:sequenceFlow id="Inner_Flow_Timeout" sourceRef="Inner_TimerBoundary" targetRef="Inner_TimeoutEnd" />
      <bpmn:incoming>Flow_E1_start</bpmn:incoming>
      <bpmn:outgoing>Flow_end</bpmn:outgoing>
    </bpmn:subProcess>
    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_E1_start" sourceRef="StartEvent_E1" targetRef="SubProcess_WithBoundary" />
    <bpmn:sequenceFlow id="Flow_end" sourceRef="SubProcess_WithBoundary" targetRef="EndEvent_1" />
  </bpmn:process>
