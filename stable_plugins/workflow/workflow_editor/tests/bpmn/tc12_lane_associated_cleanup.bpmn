<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:qhana="https://github.com/qhana"
  id="Definitions_TC12_LaneAssocCleanup"
  targetNamespace="http://qhana.example/testcases">

  <bpmn:collaboration id="Collab_1">
    <bpmn:participant id="Participant_1" name="Main Participant" processRef="tc12_lane_assoc_cleanup" />
  </bpmn:collaboration>

  <bpmn:process id="tc12_lane_assoc_cleanup" name="TC12 Lane + Association Cleanup" isExecutable="true">
    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_REST" name="REST Lane">
        <bpmn:flowNodeRef>UserTask_Input</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>ManualTask_Review</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_EXEC" name="EXEC Lane">
        <bpmn:flowNodeRef>QHanaTask_HelloWorld</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="UserTask_Input" name="Input (REST)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:manualTask id="ManualTask_Review" name="Manual Review (REST)">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </bpmn:manualTask>

    <bpmn:serviceTask id="QHanaTask_HelloWorld" name="HelloWorld (QHAna)"
                      camunda:type="external" camunda:topic="qhana-task"
                      qhana:customFlag="keep-exec">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="UserTask_Input"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="ManualTask_Review"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="ManualTask_Review" targetRef="QHanaTask_HelloWorld"/>
    <bpmn:sequenceFlow id="Flow_4" sourceRef="QHanaTask_HelloWorld" targetRef="EndEvent_1"/>

    <!-- Artifacts for association cleanup -->
    <bpmn:dataObject id="DataObject_1" name="SharedInput"/>
    <bpmn:dataObjectReference id="DataObjectRef_1" name="SharedInputRef" dataObjectRef="DataObject_1"/>
    <bpmn:textAnnotation id="TextAnnotation_1">
      <bpmn:text>Review note attached only to the manual task.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_2">
      <bpmn:text>Plugin note attached to the QHAna task.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:group id="Group_1" categoryValueRef="CategoryValue_1"/>

    <!-- Should survive only where both endpoints exist -->
    <bpmn:association id="Assoc_Data_User" sourceRef="DataObjectRef_1" targetRef="UserTask_Input"/>
    <bpmn:association id="Assoc_Note_Manual" sourceRef="TextAnnotation_1" targetRef="ManualTask_Review"/>
    <bpmn:association id="Assoc_Note_QHana" sourceRef="TextAnnotation_2" targetRef="QHanaTask_HelloWorld"/>
  </bpmn:process>

  <bpmn:category id="Category_1">
    <bpmn:categoryValue id="CategoryValue_1" value="review-group"/>
  </bpmn:category>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Collab_1">
      <bpmndi:BPMNShape id="Shape_Participant_1" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="80" y="60" width="980" height="320"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Lane_REST" bpmnElement="Lane_REST" isHorizontal="true">
        <dc:Bounds x="110" y="60" width="950" height="170"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_EXEC" bpmnElement="Lane_EXEC" isHorizontal="true">
        <dc:Bounds x="110" y="230" width="950" height="150"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_StartEvent_1" bpmnElement="StartEvent_1">
        <dc:Bounds x="150" y="125" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_UserTask_Input" bpmnElement="UserTask_Input">
        <dc:Bounds x="240" y="103" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ManualTask_Review" bpmnElement="ManualTask_Review">
        <dc:Bounds x="400" y="103" width="110" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_QHanaTask_HelloWorld" bpmnElement="QHanaTask_HelloWorld">
        <dc:Bounds x="610" y="265" width="110" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_1" bpmnElement="EndEvent_1">
        <dc:Bounds x="800" y="287" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_DataObjectRef_1" bpmnElement="DataObjectRef_1">
        <dc:Bounds x="250" y="20" width="36" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_TextAnnotation_1" bpmnElement="TextAnnotation_1">
        <dc:Bounds x="390" y="10" width="140" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_TextAnnotation_2" bpmnElement="TextAnnotation_2">
        <dc:Bounds x="740" y="245" width="150" height="50"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Group_1" bpmnElement="Group_1">
        <dc:Bounds x="220" y="85" width="320" height="115"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Edge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="186" y="143"/>
        <di:waypoint x="240" y="143"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="340" y="143"/>
        <di:waypoint x="400" y="143"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_3" bpmnElement="Flow_3">
        <di:waypoint x="510" y="143"/>
        <di:waypoint x="560" y="143"/>
        <di:waypoint x="560" y="305"/>
        <di:waypoint x="610" y="305"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_4" bpmnElement="Flow_4">
        <di:waypoint x="720" y="305"/>
        <di:waypoint x="800" y="305"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Assoc_Data_User" bpmnElement="Assoc_Data_User">
        <di:waypoint x="268" y="70"/>
        <di:waypoint x="268" y="103"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Assoc_Note_Manual" bpmnElement="Assoc_Note_Manual">
        <di:waypoint x="460" y="60"/>
        <di:waypoint x="455" y="103"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Assoc_Note_QHana" bpmnElement="Assoc_Note_QHana">
        <di:waypoint x="740" y="270"/>
        <di:waypoint x="720" y="290"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
