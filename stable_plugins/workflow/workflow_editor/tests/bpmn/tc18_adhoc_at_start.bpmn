<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:qhana="https://github.com/qhana"
  id="Definitions_tc18_adhoc_at_start"
  targetNamespace="http://qhana.example/testcases">

  <bpmn:process
    id="tc18_adhoc_at_start"
    name="TC18 - Adhoc at Start"
    isExecutable="true"
    camunda:versionTag="0.2">

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:adHocSubProcess id="AdHocSubProcess_Init" name="Project Initialization (Ad-hoc)" ordering="Parallel">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>

      <qhana:qHAnaServiceTask id="QHanaTask_DefineScope" name="define-project-scope">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">define-project-scope</camunda:inputParameter>
            <camunda:inputParameter name="qinput.init">start</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.scopeData">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>

      <qhana:qHAnaServiceTask id="QHanaTask_AssignTeam" name="assign-team-members">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">assign-team-members</camunda:inputParameter>
            <camunda:inputParameter name="qinput.init">start</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.teamData">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
    </bpmn:adHocSubProcess>

    <qhana:qHAnaServiceTask id="QHanaTask_Provision" name="provision-cloud-resources">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">provision-cloud-resources</camunda:inputParameter>
          <camunda:inputParameter name="qinput.scope">${qoutput.scopeData}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.cloudData">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </qhana:qHAnaServiceTask>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="AdHocSubProcess_Init" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="AdHocSubProcess_Init" targetRef="QHanaTask_Provision" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="QHanaTask_Provision" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_tc18">
    <bpmndi:BPMNPlane id="BPMNPlane_tc18" bpmnElement="tc18_adhoc_at_start">

      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="80" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="AdHocSubProcess_Init_di" bpmnElement="AdHocSubProcess_Init" isExpanded="true">
        <dc:Bounds x="180" y="123" width="420" height="190"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_DefineScope_di" bpmnElement="QHanaTask_DefineScope">
        <dc:Bounds x="230" y="178" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_AssignTeam_di" bpmnElement="QHanaTask_AssignTeam">
        <dc:Bounds x="410" y="178" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_Provision_di" bpmnElement="QHanaTask_Provision">
        <dc:Bounds x="670" y="178" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="910" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="116" y="218"/>
        <di:waypoint x="180" y="218"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="600" y="218"/>
        <di:waypoint x="670" y="218"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="840" y="218"/>
        <di:waypoint x="910" y="218"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>