<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:qhana="https://github.com/qhana"
  id="Definitions_tc11_xor_adhoc_inside_branch"
  targetNamespace="http://qhana.example/testcases">

  <bpmn:process
    id="tc11_xor_adhoc_inside_branch"
    name="TC11 - XOR Adhoc Inside Branch"
    isExecutable="true"
    camunda:versionTag="0.2">

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="UserTask_Input" name="Submit Content">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.contentUrl" label="Content URL" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_Split" name="Content Filter Route" default="Flow_3B">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3A</bpmn:outgoing>
      <bpmn:outgoing>Flow_3B</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <qhana:qHAnaServiceTask id="QHanaTask_ExtractMeta" name="extract-metadata">
      <bpmn:incoming>Flow_3A</bpmn:incoming>
      <bpmn:outgoing>Flow_4A</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">extract-metadata</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.contentUrl}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.contentMeta">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </qhana:qHAnaServiceTask>

    <bpmn:adHocSubProcess id="AdHocSubProcess_Manual" name="Manual Moderation" ordering="Parallel">
      <bpmn:incoming>Flow_4A</bpmn:incoming>
      <bpmn:outgoing>Flow_5A</bpmn:outgoing>

      <qhana:qHAnaServiceTask id="QHanaTask_ReviewVideo" name="review-video">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">review-video</camunda:inputParameter>
            <camunda:inputParameter name="qinput.meta">${qoutput.contentMeta}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.videoReview">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>

      <qhana:qHAnaServiceTask id="QHanaTask_CheckHistory" name="check-user-history">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">check-user-history</camunda:inputParameter>
            <camunda:inputParameter name="qinput.meta">${qoutput.contentMeta}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.historyReview">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
    </bpmn:adHocSubProcess>

    <qhana:qHAnaServiceTask id="QHanaTask_ApplyWarnings" name="apply-warnings">
      <bpmn:incoming>Flow_5A</bpmn:incoming>
      <bpmn:outgoing>Flow_6A</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">apply-warnings</camunda:inputParameter>
          <camunda:inputParameter name="qinput.meta">${qoutput.contentMeta}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.moderationResult">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </qhana:qHAnaServiceTask>

    <qhana:qHAnaServiceTask id="QHanaTask_AutoModerate" name="auto-moderate">
      <bpmn:incoming>Flow_3B</bpmn:incoming>
      <bpmn:outgoing>Flow_6B</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">auto-moderate</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.contentUrl}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.moderationResult">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </qhana:qHAnaServiceTask>

    <bpmn:exclusiveGateway id="Gateway_Merge" name="Merge Tagging">
      <bpmn:incoming>Flow_6A</bpmn:incoming>
      <bpmn:incoming>Flow_6B</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_7</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="UserTask_Input" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="Gateway_Split" />

    <bpmn:sequenceFlow id="Flow_3A" name="High Risk" sourceRef="Gateway_Split" targetRef="QHanaTask_ExtractMeta">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${riskLevel == 'High'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_4A" sourceRef="QHanaTask_ExtractMeta" targetRef="AdHocSubProcess_Manual" />
    <bpmn:sequenceFlow id="Flow_5A" sourceRef="AdHocSubProcess_Manual" targetRef="QHanaTask_ApplyWarnings" />
    <bpmn:sequenceFlow id="Flow_6A" sourceRef="QHanaTask_ApplyWarnings" targetRef="Gateway_Merge" />

    <bpmn:sequenceFlow id="Flow_3B" name="Default" sourceRef="Gateway_Split" targetRef="QHanaTask_AutoModerate" />
    <bpmn:sequenceFlow id="Flow_6B" sourceRef="QHanaTask_AutoModerate" targetRef="Gateway_Merge" />

    <bpmn:sequenceFlow id="Flow_7" sourceRef="Gateway_Merge" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_tc11">
    <bpmndi:BPMNPlane id="BPMNPlane_tc11" bpmnElement="tc11_xor_adhoc_inside_branch">

      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="80" y="450" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="UserTask_Input_di" bpmnElement="UserTask_Input">
        <dc:Bounds x="160" y="428" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Split_di" bpmnElement="Gateway_Split" isMarkerVisible="true">
        <dc:Bounds x="390" y="443" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="380" y="400" width="70" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_ExtractMeta_di" bpmnElement="QHanaTask_ExtractMeta">
        <dc:Bounds x="490" y="160" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="AdHocSubProcess_Manual_di" bpmnElement="AdHocSubProcess_Manual" isExpanded="true">
        <dc:Bounds x="720" y="105" width="420" height="190"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_ReviewVideo_di" bpmnElement="QHanaTask_ReviewVideo">
        <dc:Bounds x="770" y="160" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_CheckHistory_di" bpmnElement="QHanaTask_CheckHistory">
        <dc:Bounds x="950" y="160" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_ApplyWarnings_di" bpmnElement="QHanaTask_ApplyWarnings">
        <dc:Bounds x="1200" y="160" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_AutoModerate_di" bpmnElement="QHanaTask_AutoModerate">
        <dc:Bounds x="845" y="560" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Merge_di" bpmnElement="Gateway_Merge" isMarkerVisible="true">
        <dc:Bounds x="1430" y="443" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1415" y="500" width="80" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1530" y="450" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="116" y="468"/>
        <di:waypoint x="160" y="468"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="330" y="468"/>
        <di:waypoint x="390" y="468"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3A_di" bpmnElement="Flow_3A">
        <di:waypoint x="415" y="443"/>
        <di:waypoint x="415" y="200"/>
        <di:waypoint x="490" y="200"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="425" y="280" width="50" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4A_di" bpmnElement="Flow_4A">
        <di:waypoint x="660" y="200"/>
        <di:waypoint x="720" y="200"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5A_di" bpmnElement="Flow_5A">
        <di:waypoint x="1140" y="200"/>
        <di:waypoint x="1200" y="200"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6A_di" bpmnElement="Flow_6A">
        <di:waypoint x="1370" y="200"/>
        <di:waypoint x="1455" y="200"/>
        <di:waypoint x="1455" y="443"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3B_di" bpmnElement="Flow_3B">
        <di:waypoint x="415" y="493"/>
        <di:waypoint x="415" y="600"/>
        <di:waypoint x="845" y="600"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="430" y="580" width="40" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_6B_di" bpmnElement="Flow_6B">
        <di:waypoint x="1015" y="600"/>
        <di:waypoint x="1455" y="600"/>
        <di:waypoint x="1455" y="493"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_7_di" bpmnElement="Flow_7">
        <di:waypoint x="1480" y="468"/>
        <di:waypoint x="1530" y="468"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>