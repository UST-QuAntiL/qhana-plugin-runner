<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:qhana="https://github.com/qhana"
  id="Definitions_tc33_pool_lane_preservation"
  targetNamespace="http://qhana.example/testcases">

  <bpmn:collaboration id="Collaboration_tc33">
    <bpmn:participant id="Participant_1" name="IT Department" processRef="tc33_pool_lane_preservation" />
  </bpmn:collaboration>

  <bpmn:process
    id="tc33_pool_lane_preservation"
    name="TC33 - Pool Lane Preservation"
    isExecutable="true"
    camunda:versionTag="0.2">

    <bpmn:laneSet id="LaneSet_1">
      <bpmn:lane id="Lane_1" name="System Engineers">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>QHanaTask_Config</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>AdHocSubProcess_Review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <qhana:qHAnaServiceTask id="QHanaTask_Config" name="run-system-config">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">run-system-config</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.configResult">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </qhana:qHAnaServiceTask>

    <bpmn:adHocSubProcess id="AdHocSubProcess_Review" name="Verify Configuration" ordering="Parallel">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>

      <qhana:qHAnaServiceTask id="QHanaTask_ManualCheck" name="manual-check">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">manual-check</camunda:inputParameter>
            <camunda:inputParameter name="qinput.data">${qoutput.configResult}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.checkLog">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
    </bpmn:adHocSubProcess>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="QHanaTask_Config" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="QHanaTask_Config" targetRef="AdHocSubProcess_Review" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="AdHocSubProcess_Review" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_tc33">
    <bpmndi:BPMNPlane id="BPMNPlane_tc33" bpmnElement="Collaboration_tc33">

      <!-- Pool Shape -->
      <bpmndi:BPMNShape id="Participant_1_di" bpmnElement="Participant_1" isHorizontal="true">
        <dc:Bounds x="50" y="50" width="800" height="300" />
      </bpmndi:BPMNShape>

      <!-- Lane Shape -->
      <bpmndi:BPMNShape id="Lane_1_di" bpmnElement="Lane_1" isHorizontal="true">
        <dc:Bounds x="80" y="50" width="770" height="300" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="120" y="182" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_Config_di" bpmnElement="QHanaTask_Config">
        <dc:Bounds x="250" y="160" width="150" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="AdHocSubProcess_Review_di" bpmnElement="AdHocSubProcess_Review" isExpanded="true">
        <dc:Bounds x="480" y="110" width="200" height="180"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_ManualCheck_di" bpmnElement="QHanaTask_ManualCheck">
        <dc:Bounds x="505" y="160" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="750" y="182" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="156" y="200"/>
        <di:waypoint x="250" y="200"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="400" y="200"/>
        <di:waypoint x="480" y="200"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="680" y="200"/>
        <di:waypoint x="750" y="200"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>