<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:qhana="https://github.com/qhana"
  id="Definitions_tc12_xor_default_flow_preservation"
  targetNamespace="http://qhana.example/testcases">

  <bpmn:process
    id="tc12_xor_default_flow_preservation"
    name="TC12 - XOR Default Flow Preservation"
    isExecutable="true"
    camunda:versionTag="0.2">

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="UserTask_Input" name="Place Order">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.orderData" label="Order Data" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="Gateway_Split" name="Check Stock Availability" default="Flow_3A">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3A</bpmn:outgoing>
      <bpmn:outgoing>Flow_3B</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <qhana:qHAnaServiceTask id="QHanaTask_ProcessPayment" name="process-payment">
      <bpmn:incoming>Flow_3A</bpmn:incoming>
      <bpmn:outgoing>Flow_4A</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">process-payment</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.orderData}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.paymentReceipt">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </qhana:qHAnaServiceTask>

    <bpmn:adHocSubProcess id="AdHocSubProcess_Backorder" name="Backorder Resolution" ordering="Parallel">
      <bpmn:incoming>Flow_3B</bpmn:incoming>
      <bpmn:outgoing>Flow_4B</bpmn:outgoing>

      <qhana:qHAnaServiceTask id="QHanaTask_ContactSupplier" name="contact-supplier">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">contact-supplier</camunda:inputParameter>
            <camunda:inputParameter name="qinput.data">${qoutput.orderData}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.supplierUpdate">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>

      <qhana:qHAnaServiceTask id="QHanaTask_NotifyCustomer" name="notify-customer">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">notify-customer</camunda:inputParameter>
            <camunda:inputParameter name="qinput.data">${qoutput.orderData}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.customerUpdate">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>

    </bpmn:adHocSubProcess>

    <bpmn:exclusiveGateway id="Gateway_Merge" name="Finalize Order">
      <bpmn:incoming>Flow_4A</bpmn:incoming>
      <bpmn:incoming>Flow_4B</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_5</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="UserTask_Input" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="Gateway_Split" />

    <bpmn:sequenceFlow id="Flow_3A" name="Default (In Stock)" sourceRef="Gateway_Split" targetRef="QHanaTask_ProcessPayment" />

    <bpmn:sequenceFlow id="Flow_3B" name="Out of Stock" sourceRef="Gateway_Split" targetRef="AdHocSubProcess_Backorder">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${stock == 'Empty'}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>

    <bpmn:sequenceFlow id="Flow_4A" sourceRef="QHanaTask_ProcessPayment" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_4B" sourceRef="AdHocSubProcess_Backorder" targetRef="Gateway_Merge" />
    <bpmn:sequenceFlow id="Flow_5" sourceRef="Gateway_Merge" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_tc12">
    <bpmndi:BPMNPlane id="BPMNPlane_tc12" bpmnElement="tc12_xor_default_flow_preservation">

      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="80" y="250" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="UserTask_Input_di" bpmnElement="UserTask_Input">
        <dc:Bounds x="160" y="228" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Split_di" bpmnElement="Gateway_Split" isMarkerVisible="true">
        <dc:Bounds x="390" y="243" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="375" y="210" width="80" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_ProcessPayment_di" bpmnElement="QHanaTask_ProcessPayment">
        <dc:Bounds x="550" y="80" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="AdHocSubProcess_Backorder_di" bpmnElement="AdHocSubProcess_Backorder" isExpanded="true">
        <dc:Bounds x="550" y="325" width="420" height="190"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_ContactSupplier_di" bpmnElement="QHanaTask_ContactSupplier">
        <dc:Bounds x="600" y="380" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_NotifyCustomer_di" bpmnElement="QHanaTask_NotifyCustomer">
        <dc:Bounds x="780" y="380" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Gateway_Merge_di" bpmnElement="Gateway_Merge" isMarkerVisible="true">
        <dc:Bounds x="1050" y="243" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1040" y="300" width="70" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1150" y="250" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="116" y="268"/>
        <di:waypoint x="160" y="268"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="330" y="268"/>
        <di:waypoint x="390" y="268"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3A_di" bpmnElement="Flow_3A">
        <di:waypoint x="415" y="243"/>
        <di:waypoint x="415" y="120"/>
        <di:waypoint x="550" y="120"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="430" y="100" width="90" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3B_di" bpmnElement="Flow_3B">
        <di:waypoint x="415" y="293"/>
        <di:waypoint x="415" y="420"/>
        <di:waypoint x="550" y="420"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="430" y="430" width="60" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4A_di" bpmnElement="Flow_4A">
        <di:waypoint x="720" y="120"/>
        <di:waypoint x="1075" y="120"/>
        <di:waypoint x="1075" y="243"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4B_di" bpmnElement="Flow_4B">
        <di:waypoint x="970" y="420"/>
        <di:waypoint x="1075" y="420"/>
        <di:waypoint x="1075" y="293"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_5_di" bpmnElement="Flow_5">
        <di:waypoint x="1100" y="268"/>
        <di:waypoint x="1150" y="268"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>