<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:qhana="https://github.com/qhana"
  id="Definitions_TC10_ServiceTask_NonExec"
  targetNamespace="http://qhana.example/testcases">

  <bpmn:process id="tc10_service_task_nonexec" name="TC10 ServiceTask Non-Exec Mapping" isExecutable="true">
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="UserTask_Input" name="Prepare Input (REST)">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Should remain REST: external service task but NOT a QHAna topic -->
    <bpmn:serviceTask id="ServiceTask_NonQHana" name="External Service (non-QHAna)"
                      camunda:type="external" camunda:topic="other-topic"
                      qhana:customFlag="nonexec-service">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="source">manual-input</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </bpmn:serviceTask>

    <!-- Should remain EXEC -->
    <bpmn:serviceTask id="QHanaTask_HelloWorld" name="HelloWorld (QHAna)"
                      camunda:type="external" camunda:topic="qhana-task"
                      qhana:customFlag="exec-service">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">hello-world</camunda:inputParameter>
          <camunda:inputParameter name="qinput.inputStr">${qoutput.userInput}</camunda:inputParameter>
          <camunda:outputParameter name="result.qoutput.helloWorldResult">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </bpmn:serviceTask>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="UserTask_Input" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="ServiceTask_NonQHana" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="ServiceTask_NonQHana" targetRef="QHanaTask_HelloWorld" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="QHanaTask_HelloWorld" targetRef="EndEvent_1" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="tc10_service_task_nonexec">
      <bpmndi:BPMNShape id="Shape_StartEvent_1" bpmnElement="StartEvent_1">
        <dc:Bounds x="120" y="110" width="36" height="36"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_UserTask_Input" bpmnElement="UserTask_Input">
        <dc:Bounds x="210" y="88" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_ServiceTask_NonQHana" bpmnElement="ServiceTask_NonQHana">
        <dc:Bounds x="360" y="88" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_QHanaTask_HelloWorld" bpmnElement="QHanaTask_HelloWorld">
        <dc:Bounds x="510" y="88" width="100" height="80"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_1" bpmnElement="EndEvent_1">
        <dc:Bounds x="670" y="110" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Edge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="156" y="128"/>
        <di:waypoint x="210" y="128"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="310" y="128"/>
        <di:waypoint x="360" y="128"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_3" bpmnElement="Flow_3">
        <di:waypoint x="460" y="128"/>
        <di:waypoint x="510" y="128"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_4" bpmnElement="Flow_4">
        <di:waypoint x="610" y="128"/>
        <di:waypoint x="670" y="128"/>
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
