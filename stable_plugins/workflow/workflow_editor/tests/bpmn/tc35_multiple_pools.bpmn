<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:qhana="https://github.com/qhana"
  id="Definitions_tc35_multiple_pools"
  targetNamespace="http://qhana.example/testcases">

  <bpmn:collaboration id="Collaboration_tc35">
    <bpmn:participant id="Participant_Customer" name="Customer" />
    <bpmn:participant id="Participant_Vendor" name="Vendor" processRef="tc35_multiple_pools" />

    <bpmn:messageFlow id="MessageFlow_1" sourceRef="Participant_Customer" targetRef="QHanaTask_ReceiveOrder" />
  </bpmn:collaboration>

  <bpmn:process
    id="tc35_multiple_pools"
    name="TC35 - Multiple Pools"
    isExecutable="true"
    camunda:versionTag="0.2">

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <qhana:qHAnaServiceTask id="QHanaTask_ReceiveOrder" name="process-order">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">process-order</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.orderData">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </qhana:qHAnaServiceTask>

    <bpmn:adHocSubProcess id="AdHocSubProcess_Fulfillment" name="Manual Fulfillment" ordering="Parallel">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>

      <qhana:qHAnaServiceTask id="QHanaTask_PackOrder" name="pack-order">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">pack-order</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.shippingLog">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
    </bpmn:adHocSubProcess>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_3</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="QHanaTask_ReceiveOrder" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="QHanaTask_ReceiveOrder" targetRef="AdHocSubProcess_Fulfillment" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="AdHocSubProcess_Fulfillment" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_tc35">
    <bpmndi:BPMNPlane id="BPMNPlane_tc35" bpmnElement="Collaboration_tc35">

      <bpmndi:BPMNShape id="Participant_Customer_di" bpmnElement="Participant_Customer" isHorizontal="true">
        <dc:Bounds x="50" y="50" width="800" height="100" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Participant_Vendor_di" bpmnElement="Participant_Vendor" isHorizontal="true">
        <dc:Bounds x="50" y="250" width="800" height="250" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="120" y="350" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_ReceiveOrder_di" bpmnElement="QHanaTask_ReceiveOrder">
        <dc:Bounds x="250" y="328" width="150" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="AdHocSubProcess_Fulfillment_di" bpmnElement="AdHocSubProcess_Fulfillment" isExpanded="true">
        <dc:Bounds x="480" y="280" width="200" height="180"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_PackOrder_di" bpmnElement="QHanaTask_PackOrder">
        <dc:Bounds x="505" y="330" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="750" y="350" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="156" y="368"/>
        <di:waypoint x="250" y="368"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="400" y="368"/>
        <di:waypoint x="480" y="368"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="680" y="368"/>
        <di:waypoint x="750" y="368"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="MessageFlow_1_di" bpmnElement="MessageFlow_1">
        <di:waypoint x="325" y="150"/>
        <di:waypoint x="325" y="328"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>