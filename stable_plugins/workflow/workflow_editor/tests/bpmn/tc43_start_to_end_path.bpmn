<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions 
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" 
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" 
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" 
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI" 
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn" 
  xmlns:qhana="https://github.com/qhana" 
  id="Def_tc43" 
  targetNamespace="http://qhana.example/testcases">

  <bpmn:process id="tc43_start_to_end_path" name="TC43 - Start to End Path Validation" isExecutable="true" camunda:versionTag="0.1">
    
    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:adHocSubProcess id="AdHoc_1" name="Manual Setup" ordering="Parallel">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:userTask id="Setup_Task" name="Configure Parameters" />
    </bpmn:adHocSubProcess>

    <qhana:qHAnaServiceTask id="Task_Exec" name="Automated Process" camunda:type="external" camunda:topic="qhana-task">
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaPlugin">data-processor</camunda:inputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
    </qhana:qHAnaServiceTask>

    <bpmn:adHocSubProcess id="AdHoc_2" name="Manual Review" ordering="Parallel">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>
      <bpmn:serviceTask id="Review_Task" name="Check Outputs" camunda:type="external" camunda:topic="qhana-task">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaPlugin">placeholder-check-outputs</camunda:inputParameter>
            <camunda:inputParameter name="qhanaPluginVersion">v0-1-0</camunda:inputParameter>
            <camunda:inputParameter name="qhanaName">Check Outputs</camunda:inputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </bpmn:serviceTask>
    </bpmn:adHocSubProcess>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="AdHoc_1" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="AdHoc_1" targetRef="Task_Exec" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_Exec" targetRef="AdHoc_2" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="AdHoc_2" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="tc43_start_to_end_path">
      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="150" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AdHoc_1_di" bpmnElement="AdHoc_1" isExpanded="true">
        <dc:Bounds x="250" y="160" width="150" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_Exec_di" bpmnElement="Task_Exec">
        <dc:Bounds x="450" y="180" width="100" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="AdHoc_2_di" bpmnElement="AdHoc_2" isExpanded="true">
        <dc:Bounds x="600" y="160" width="150" height="120" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="800" y="200" width="36" height="36" />
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="186" y="218" />
        <di:waypoint x="250" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="400" y="218" />
        <di:waypoint x="450" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="550" y="218" />
        <di:waypoint x="600" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="750" y="218" />
        <di:waypoint x="800" y="218" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNShape id="Setup_Task_di" bpmnElement="Setup_Task">
        <dc:Bounds x="275" y="195" width="100" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Review_Task_di" bpmnElement="Review_Task">
        <dc:Bounds x="625" y="195" width="100" height="70" />
      </bpmndi:BPMNShape>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>