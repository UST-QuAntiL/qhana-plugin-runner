<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:qhana="https://github.com/qhana"
  id="Definitions_tc29_association_cleanup"
  targetNamespace="http://qhana.example/testcases">

  <bpmn:process
    id="tc29_association_cleanup"
    name="TC29 - Association Cleanup"
    isExecutable="true"
    camunda:versionTag="0.2">

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="UserTask_Input" name="Upload Raw Logs">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.logData" label="Log Data" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
    </bpmn:userTask>

    <qhana:qHAnaServiceTask id="QHanaTask_FilterLogs" name="filter-logs">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">filter-logs</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.logData}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.filteredLogs">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </qhana:qHAnaServiceTask>

    <bpmn:textAnnotation id="TextAnnotation_1">
      <bpmn:text>Critical: This plugin will be extracted. Ensure the association line does not crash the Camunda engine by becoming a dangling edge.</bpmn:text>
    </bpmn:textAnnotation>

    <bpmn:association id="Association_1" sourceRef="QHanaTask_FilterLogs" targetRef="TextAnnotation_1" />

    <bpmn:adHocSubProcess id="AdHocSubProcess_Audit" name="Audit Review" ordering="Parallel">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>

      <qhana:qHAnaServiceTask id="QHanaTask_ReviewLogs" name="review-logs">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">review-logs</camunda:inputParameter>
            <camunda:inputParameter name="qinput.data">${qoutput.filteredLogs}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.auditResult">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
    </bpmn:adHocSubProcess>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="UserTask_Input" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="QHanaTask_FilterLogs" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="QHanaTask_FilterLogs" targetRef="AdHocSubProcess_Audit" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="AdHocSubProcess_Audit" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_tc29">
    <bpmndi:BPMNPlane id="BPMNPlane_tc29" bpmnElement="tc29_association_cleanup">

      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="80" y="250" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="UserTask_Input_di" bpmnElement="UserTask_Input">
        <dc:Bounds x="160" y="228" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_FilterLogs_di" bpmnElement="QHanaTask_FilterLogs">
        <dc:Bounds x="390" y="228" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="TextAnnotation_1_di" bpmnElement="TextAnnotation_1">
        <dc:Bounds x="420" y="80" width="220" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Association_1_di" bpmnElement="Association_1">
        <di:waypoint x="475" y="228"/>
        <di:waypoint x="475" y="150"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNShape id="AdHocSubProcess_Audit_di" bpmnElement="AdHocSubProcess_Audit" isExpanded="true">
        <dc:Bounds x="620" y="173" width="420" height="190"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_ReviewLogs_di" bpmnElement="QHanaTask_ReviewLogs">
        <dc:Bounds x="670" y="228" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1100" y="250" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="116" y="268"/>
        <di:waypoint x="160" y="268"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="330" y="268"/>
        <di:waypoint x="390" y="268"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="560" y="268"/>
        <di:waypoint x="620" y="268"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="1040" y="268"/>
        <di:waypoint x="1100" y="268"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>