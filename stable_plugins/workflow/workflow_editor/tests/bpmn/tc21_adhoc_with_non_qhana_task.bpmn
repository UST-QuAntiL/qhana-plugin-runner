<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:qhana="https://github.com/qhana"
  id="Definitions_tc21_adhoc_with_non_qhana_task"
  targetNamespace="http://qhana.example/testcases">

  <bpmn:process
    id="tc21_adhoc_with_non_qhana_task"
    name="TC21 - Adhoc with Non-QHAna Task"
    isExecutable="true"
    camunda:versionTag="0.2">

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="UserTask_Input" name="Submit Travel Request">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.travelDetails" label="Travel Details" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
    </bpmn:userTask>

    <qhana:qHAnaServiceTask id="QHanaTask_CheckBudget" name="verify-budget-allocation">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">verify-budget-allocation</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.travelDetails}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.budgetStatus">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </qhana:qHAnaServiceTask>

    <bpmn:adHocSubProcess id="AdHocSubProcess_Approval" name="Manager Review Block" ordering="Parallel">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>

      <qhana:qHAnaServiceTask id="QHanaTask_ReviewItinerary" name="review-itinerary">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">review-itinerary</camunda:inputParameter>
            <camunda:inputParameter name="qinput.data">${qoutput.travelDetails}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.itineraryStatus">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>

      <bpmn:scriptTask id="ScriptTask_LogAudit" name="Log Audit Trail" scriptFormat="javascript">
        <bpmn:script>
          var status = execution.getVariable('qoutput.budgetStatus');
          console.log("Auditing travel request with status: " + status);
        </bpmn:script>
      </bpmn:scriptTask>

      <bpmn:manualTask id="ManualTask_CallAgency" name="Call Travel Agency" />

    </bpmn:adHocSubProcess>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="UserTask_Input" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="QHanaTask_CheckBudget" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="QHanaTask_CheckBudget" targetRef="AdHocSubProcess_Approval" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="AdHocSubProcess_Approval" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_tc21">
    <bpmndi:BPMNPlane id="BPMNPlane_tc21" bpmnElement="tc21_adhoc_with_non_qhana_task">

      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="80" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="UserTask_Input_di" bpmnElement="UserTask_Input">
        <dc:Bounds x="160" y="178" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_CheckBudget_di" bpmnElement="QHanaTask_CheckBudget">
        <dc:Bounds x="390" y="178" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="AdHocSubProcess_Approval_di" bpmnElement="AdHocSubProcess_Approval" isExpanded="true">
        <dc:Bounds x="620" y="123" width="600" height="190"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_ReviewItinerary_di" bpmnElement="QHanaTask_ReviewItinerary">
        <dc:Bounds x="660" y="178" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="ScriptTask_LogAudit_di" bpmnElement="ScriptTask_LogAudit">
        <dc:Bounds x="850" y="178" width="120" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="ManualTask_CallAgency_di" bpmnElement="ManualTask_CallAgency">
        <dc:Bounds x="1010" y="178" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1280" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="116" y="218"/>
        <di:waypoint x="160" y="218"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="330" y="218"/>
        <di:waypoint x="390" y="218"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="560" y="218"/>
        <di:waypoint x="620" y="218"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="1220" y="218"/>
        <di:waypoint x="1280" y="218"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>