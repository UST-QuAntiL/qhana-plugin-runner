<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:camunda="http://camunda.org/schema/1.0/bpmn"
  xmlns:qhana="https://github.com/qhana"
  id="Definitions_tc26_variable_exec_to_main"
  targetNamespace="http://qhana.example/testcases">

  <bpmn:process
    id="tc26_variable_exec_to_main"
    name="TC26 - Variable Exec to Main"
    isExecutable="true"
    camunda:versionTag="0.2">

    <bpmn:startEvent id="StartEvent_1" name="Start">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="UserTask_Input" name="Submit Customer ID">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:formData>
          <camunda:formField id="qoutput.customerId" label="Customer ID" type="string" />
        </camunda:formData>
      </bpmn:extensionElements>
    </bpmn:userTask>

    <qhana:qHAnaServiceTask id="QHanaTask_EnrichProfile" name="enrich-customer-profile">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <bpmn:extensionElements>
        <camunda:inputOutput>
          <camunda:inputParameter name="qhanaName">enrich-customer-profile</camunda:inputParameter>
          <camunda:inputParameter name="qinput.data">${qoutput.customerId}</camunda:inputParameter>
          <camunda:outputParameter name="qoutput.enrichedProfile">${output}</camunda:outputParameter>
        </camunda:inputOutput>
      </bpmn:extensionElements>
    </qhana:qHAnaServiceTask>

    <bpmn:adHocSubProcess id="AdHocSubProcess_KYC" name="Manual KYC Review (Main)" ordering="Parallel">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_4</bpmn:outgoing>

      <qhana:qHAnaServiceTask id="QHanaTask_VerifyIdentity" name="verify-identity">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">verify-identity</camunda:inputParameter>
            <camunda:inputParameter name="qinput.profile">${qoutput.enrichedProfile}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.identityVerification">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>

      <qhana:qHAnaServiceTask id="QHanaTask_CheckRisk" name="check-risk-factors">
        <bpmn:extensionElements>
          <camunda:inputOutput>
            <camunda:inputParameter name="qhanaName">check-risk-factors</camunda:inputParameter>
            <camunda:inputParameter name="qinput.profile">${qoutput.enrichedProfile}</camunda:inputParameter>
            <camunda:outputParameter name="qoutput.riskAssessment">${output}</camunda:outputParameter>
          </camunda:inputOutput>
        </bpmn:extensionElements>
      </qhana:qHAnaServiceTask>
    </bpmn:adHocSubProcess>

    <bpmn:endEvent id="EndEvent_1" name="End">
      <bpmn:incoming>Flow_4</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="UserTask_Input" />
    <bpmn:sequenceFlow id="Flow_2" sourceRef="UserTask_Input" targetRef="QHanaTask_EnrichProfile" />
    <bpmn:sequenceFlow id="Flow_3" sourceRef="QHanaTask_EnrichProfile" targetRef="AdHocSubProcess_KYC" />
    <bpmn:sequenceFlow id="Flow_4" sourceRef="AdHocSubProcess_KYC" targetRef="EndEvent_1" />

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_tc26">
    <bpmndi:BPMNPlane id="BPMNPlane_tc26" bpmnElement="tc26_variable_exec_to_main">

      <bpmndi:BPMNShape id="StartEvent_1_di" bpmnElement="StartEvent_1">
        <dc:Bounds x="80" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="UserTask_Input_di" bpmnElement="UserTask_Input">
        <dc:Bounds x="160" y="178" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_EnrichProfile_di" bpmnElement="QHanaTask_EnrichProfile">
        <dc:Bounds x="390" y="178" width="170" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="AdHocSubProcess_KYC_di" bpmnElement="AdHocSubProcess_KYC" isExpanded="true">
        <dc:Bounds x="620" y="123" width="420" height="190"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_VerifyIdentity_di" bpmnElement="QHanaTask_VerifyIdentity">
        <dc:Bounds x="670" y="178" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="QHanaTask_CheckRisk_di" bpmnElement="QHanaTask_CheckRisk">
        <dc:Bounds x="850" y="178" width="150" height="70"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="EndEvent_1_di" bpmnElement="EndEvent_1">
        <dc:Bounds x="1100" y="200" width="36" height="36"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="Flow_1_di" bpmnElement="Flow_1">
        <di:waypoint x="116" y="218"/>
        <di:waypoint x="160" y="218"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_2_di" bpmnElement="Flow_2">
        <di:waypoint x="330" y="218"/>
        <di:waypoint x="390" y="218"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_3_di" bpmnElement="Flow_3">
        <di:waypoint x="560" y="218"/>
        <di:waypoint x="620" y="218"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Flow_4_di" bpmnElement="Flow_4">
        <di:waypoint x="1040" y="218"/>
        <di:waypoint x="1100" y="218"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>